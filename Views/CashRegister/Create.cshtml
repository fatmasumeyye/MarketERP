@{
    ViewData["Title"] = "Kasa Kapanışı Oluştur";
}

<h2 class="mb-4">Kasa Kapanışı Oluştur</h2>

<div class="alert alert-info">
    Bu ekran sadece bugünkü kendi kasa hareketlerin için kapanış oluşturur.
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5>Beklenen Nakit</h5>
                <h3>@(((decimal)ViewBag.CashTotal).ToString("N2")) ₺</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5>Kart Satış Toplamı</h5>
                <h3>@(((decimal)ViewBag.CardTotal).ToString("N2")) ₺</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5>Toplam Satış</h5>
                <h3>@(((decimal)ViewBag.TotalAmount).ToString("N2")) ₺</h3>
            </div>
        </div>
    </div>
</div>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Kasadaki Nakit Tutarı</label>
        <input type="number"
               step="0.01"
               name="declaredCashAmount"
               class="form-control"
               placeholder="Kasada saydığın nakit tutarı gir"
               required />

        <small class="text-muted">
            Sistem bu tutarı beklenen nakit satış toplamı ile karşılaştıracaktır.
        </small>
    </div>

    <div class="mb-3">
        <label class="form-label">Not</label>
        <textarea name="note"
                  class="form-control"
                  rows="3"
                  placeholder="Varsa açıklama yazabilirsin..."></textarea>
    </div>

    <button type="submit" class="btn btn-primary">
        Kapanış Gönder
    </button>

    <a href="/CashRegister/MyClosings" class="btn btn-secondary">
        Geri Dön
    </a>
</form>