@model List<MarketERP.Models.Category>

@{
    ViewData["Title"] = "Kategori Yönetimi";
}

<h2 class="mb-4">Kategori Yönetimi</h2>

<form asp-action="Add" method="post" class="mb-4">
    <div class="row">
        <div class="col-md-6">
            <input type="text"
                   name="name"
                   class="form-control"
                   placeholder="Kategori adı giriniz"
                   required />
        </div>

        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">
                Kategori Ekle
            </button>
        </div>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Kategori Adı</th>
            <th width="120">İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Id</td>
                <td>@category.Name</td>

                <td>
                    <a href="/Categories/Delete/@category.Id"
                           class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>