@model MarketERP.Models.CustomerDetailViewModel
@{ ViewData["Title"] = "Müşteri Detayı"; var c = Model.Customer; }
<div class="erp-page-header"><div><span class="erp-page-eyebrow">MÜŞTERİ KARTI</span><h2>@c.FullName</h2><p>Müşteri bilgileri ve satış özeti.</p></div><div class="erp-page-actions"><a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Düzenle</a><a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a></div></div>
<div class="row g-3 mb-4"><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Toplam Alışveriş</div><div class="erp-kpi-value">@Model.TotalShopping.ToString("N2") ₺</div></div></div><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Toplam Sipariş</div><div class="erp-kpi-value">@Model.TotalOrders</div></div></div><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Son Satış</div><div class="erp-kpi-value fs-5">@(Model.LastSaleDate?.ToString("dd.MM.yyyy") ?? "Kayıt yok")</div></div></div><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Son Satış Tutarı</div><div class="erp-kpi-value">@(Model.LastSaleAmount?.ToString("N2") ?? "0,00") ₺</div></div></div></div>
<div class="card"><div class="card-header"><h3 class="erp-card-title">Müşteri Bilgileri</h3></div><div class="card-body"><div class="row g-4"><div class="col-md-4"><strong>Telefon</strong><div>@(string.IsNullOrWhiteSpace(c.Phone) ? "Tanımlanmadı" : c.Phone)</div></div><div class="col-md-4"><strong>E-posta</strong><div>@(string.IsNullOrWhiteSpace(c.Email) ? "Tanımlanmadı" : c.Email)</div></div><div class="col-md-4"><strong>İskonto</strong><div>%@c.DiscountRate.ToString("0.##")</div></div><div class="col-md-8"><strong>Adres</strong><div>@(string.IsNullOrWhiteSpace(c.Address) ? "Tanımlanmadı" : c.Address)</div></div><div class="col-md-4"><strong>Durum</strong><div><span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Aktif" : "Pasif")</span></div></div></div></div></div>
