@model List<MarketERP.Models.Customer>
@using MarketERP.Helpers

@{
    ViewData["Title"] = "Müşteri Yönetimi";

    var status = ViewBag.Status as string ?? "active";
    var canUpdateCustomer = Context.HasPermission("customer.update");
    var canCreateCustomer = Context.HasPermission("customer.create");
    var canManageDiscount =
        Context.HasPermission("sale.wholesale.create")
        || Context.HasPermission("role.manage")
        || Context.HasPermission("user.manage")
        || Context.HasPermission("sale.view.all");
}

<h2 class="mb-4">Müşteri Yönetimi</h2>

@if (canManageDiscount)
{
    <div class="alert alert-info">
        <strong>Müşteri iskonto yönetimi:</strong>
        Bu ekranda müşterilerin iskonto oranlarını görebilir ve yeni müşteri eklerken iskonto oranı tanımlayabilirsin.
        Bu oran satış ve toptan satış işlemlerinde indirim hesabı için kullanılacaktır.
    </div>
}

<form method="get" class="erp-filter-bar mb-3"><label for="status" class="form-label mb-0">Durum</label><select id="status" name="status" class="form-select" style="max-width:220px"><option value="active" selected="@(status == "active")">Aktif</option><option value="inactive" selected="@(status == "inactive")">Pasif</option><option value="all" selected="@(status == "all")">Tümü</option></select><button type="submit" class="btn btn-outline-primary">Filtrele</button></form>

@if (canCreateCustomer)
{
<form asp-action="Add" method="post" class="mb-4">
    <div class="row mb-2">
        <div class="col-md-3">
            <input type="text"
                   name="FullName"
                   class="form-control"
                   placeholder="Ad Soyad / Firma Adı"
                   required />
        </div>

        <div class="col-md-2">
            <input type="text"
                   name="Phone"
                   class="form-control"
                   placeholder="Telefon" />
        </div>

        <div class="col-md-2">
            <input type="email"
                   name="Email"
                   class="form-control"
                   placeholder="E-posta" />
        </div>

        <div class="col-md-3">
            <input type="text"
                   name="Address"
                   class="form-control"
                   placeholder="Adres" />
        </div>

        @if (canManageDiscount)
        {
            <div class="col-md-2">
                <input type="text"
                       name="DiscountRate"
                       class="form-control"
                       placeholder="İskonto % örn: 12.5"
                       inputmode="decimal" />
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">
        Müşteri Ekle
    </button>
</form>
}

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Ad Soyad / Firma</th>
            <th>Telefon</th>
            <th>E-posta</th>
            <th>Adres</th>

            @if (canManageDiscount)
            {
                <th>İskonto Oranı</th>
            }

            <th>Durum</th><th>İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var customer in Model)
        {
            <tr class="@(!customer.IsActive ? "erp-inactive-row" : null)">
                <td>@customer.Id</td>
                <td>@customer.FullName</td>
                <td>@(string.IsNullOrWhiteSpace(customer.Phone) ? "—" : customer.Phone)</td>
                <td>@(string.IsNullOrWhiteSpace(customer.Email) ? "—" : customer.Email)</td>
                <td>@(string.IsNullOrWhiteSpace(customer.Address) ? "—" : customer.Address)</td>

                @if (canManageDiscount)
                {
                    <td>
                        <form asp-action="UpdateDiscount" method="post" class="d-flex gap-2">
                            <input type="hidden" name="id" value="@customer.Id" />

                            <input type="text"
                                   name="discountRate"
                                   value="@customer.DiscountRate.ToString("0.##")"
                                   class="form-control form-control-sm"
                                   style="width: 90px;"
                                   inputmode="decimal" />

                            <button type="submit" class="btn btn-success btn-sm">
                                Kaydet
                            </button>
                        </form>
                    </td>
                }

                <td><span class="badge @(customer.IsActive ? "bg-success" : "bg-secondary")">@(customer.IsActive ? "Aktif" : "Pasif")</span></td><td>
                    <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-outline-secondary btn-sm" title="Detay"><i class="bi bi-eye"></i></a>
                    @if (canUpdateCustomer) { <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-outline-primary btn-sm" title="Düzenle"><i class="bi bi-pencil"></i></a> }
                    @if (canUpdateCustomer && customer.IsActive)
                    {
                    <form asp-action="Delete" asp-route-id="@customer.Id" method="post" class="d-inline"
                          data-confirm-title="Müşteriyi Pasif Yap"
                          data-confirm-message="Müşteri yeni işlemlerde seçilemeyecek; geçmiş kayıtları korunacaktır."
                          data-confirm-button="Pasif Yap"
                          data-confirm-type="warning">
                        <button type="submit" class="btn btn-outline-warning btn-sm"><i class="bi bi-pause-circle"></i><span>Pasif Yap</span>
                        </button>
                    </form>
                    }
                    else if (canUpdateCustomer)
                    {
                    <form asp-action="Activate" asp-route-id="@customer.Id" method="post" class="d-inline" data-confirm-title="Müşteriyi Aktifleştir" data-confirm-message="Müşteri yeniden yeni işlemlerde kullanılabilecektir." data-confirm-button="Aktifleştir" data-confirm-type="success"><button type="submit" class="btn btn-outline-success btn-sm"><i class="bi bi-play-circle"></i><span>Aktifleştir</span></button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
