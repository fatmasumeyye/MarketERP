@model List<MarketERP.Models.Customer>

@{
    ViewData["Title"] = "Müşteri Yönetimi";
}

<h2 class="mb-4">Müşteri Yönetimi</h2>

<form asp-action="Add" method="post" class="mb-4">
    <div class="row mb-2">
        <div class="col-md-3">
            <input type="text" name="FullName" class="form-control" placeholder="Ad Soyad" required />
        </div>

        <div class="col-md-3">
            <input type="text" name="Phone" class="form-control" placeholder="Telefon" />
        </div>

        <div class="col-md-3">
            <input type="email" name="Email" class="form-control" placeholder="E-posta" />
        </div>

        <div class="col-md-3">
            <input type="text" name="Address" class="form-control" placeholder="Adres" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Müşteri Ekle</button>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Ad Soyad</th>
            <th>Telefon</th>
            <th>E-posta</th>
            <th>Adres</th>
            <th>İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.Id</td>
                <td>@customer.FullName</td>
                <td>@customer.Phone</td>
                <td>@customer.Email</td>
                <td>@customer.Address</td>
                <td>
                    <a href="/Customers/Delete/@customer.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>