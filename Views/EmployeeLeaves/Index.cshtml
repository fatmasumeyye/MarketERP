@model List<MarketERP.Models.EmployeeLeave>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "İzin Yönetimi";
}

<h2 class="mb-4">İzin Yönetimi</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-warning">
            <div class="card-body text-center">
                <h6>Bekleyen</h6>
                <h3>@ViewBag.PendingCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-success">
            <div class="card-body text-center">
                <h6>Onaylanan</h6>
                <h3>@ViewBag.ApprovedCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-danger">
            <div class="card-body text-center">
                <h6>Reddedilen</h6>
                <h3>@ViewBag.RejectedCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-primary">
            <div class="card-body text-center">
                <h6>Toplam</h6>
                <h3>@ViewBag.TotalCount</h3>
            </div>
        </div>
    </div>
</div>

<form asp-action="Add" method="post" class="card p-3 mb-4">
    <h5>Yönetici Olarak İzin Kaydı Oluştur</h5>

    <div class="row">
        <div class="col-md-3">
            <label class="form-label">Çalışan</label>
            <select name="EmployeeId" class="form-control" asp-items="ViewBag.Employees">
                <option value="">Çalışan Seçiniz</option>
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Başlangıç</label>
            <input type="date" name="StartDate" class="form-control" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Bitiş</label>
            <input type="date" name="EndDate" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Neden</label>
            <input type="text" name="LeaveReason" class="form-control" />
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">
                Ekle
            </button>
        </div>
    </div>
</form>

<div class="table-responsive erp-leave-table-wrap">
<table class="table table-bordered table-striped align-middle erp-leave-table">
    <thead class="table-dark">
        <tr>
            <th class="erp-sticky-identity">Çalışan</th>
            <th>İşe Giriş</th>
            <th>Kıdem</th>
            <th>Yıllık Hak</th>
            <th>Kullanılan</th>
            <th>Bekleyen</th>
            <th>Kalan</th>
            <th>Talep Gün</th>
            <th>Başlangıç</th>
            <th>Bitiş</th>
            <th>Neden</th>
            <th>Durum</th>
            <th>İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var leave in Model)
        {
            <tr>
                <td class="erp-sticky-identity"><strong>@(leave.Employee?.FullName ?? "Tanımlanmadı")</strong></td>

                <td>
                    @(leave.Employee?.HireDate != null
                        ? leave.Employee.HireDate.Value.ToString("dd.MM.yyyy")
                        : "-")
                </td>

                <td>@leave.SeniorityYear yıl</td>
                <td>@leave.AnnualLeaveRight gün</td>
                <td>@leave.UsedLeaveDays gün</td>
                <td>@leave.PendingLeaveDays gün</td>
                <td>@leave.RemainingLeaveDays gün</td>
                <td>@leave.RequestedDays gün</td>
                <td>@leave.StartDate.ToString("dd.MM.yyyy")</td>
                <td>@leave.EndDate.ToString("dd.MM.yyyy")</td>
                <td>@leave.LeaveReason</td>

                <td>
                    @if (leave.Status == "Beklemede")
                    {
                        <span class="badge bg-warning text-dark">Beklemede</span>
                    }
                    else if (leave.Status == "Onaylandı")
                    {
                        <span class="badge bg-success">Onaylandı</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Reddedildi</span>
                    }
                </td>

                <td>
                    @if (leave.Status == "Beklemede")
                    {
                        <form asp-action="Approve" asp-route-id="@leave.Id" method="post" class="d-inline">
                            <button type="submit"
                                    class="btn btn-success btn-sm"
                                    title="Bekleyen izin talebini onayla"
                                    data-confirm-title="İzin Talebini Onayla"
                                    data-confirm-message="Bu izin talebini onaylamak istiyor musunuz?"
                                    data-confirm-button="Onayla"
                                    data-confirm-type="success">
                                Onayla
                            </button>
                        </form>

                        <form asp-action="Reject" asp-route-id="@leave.Id" method="post" class="d-inline">
                            <button type="submit"
                                    class="btn btn-warning btn-sm"
                                    title="Bekleyen izin talebini reddet"
                                    data-confirm-title="İzin Talebini Reddet"
                                    data-confirm-message="Bu izin talebini reddetmek istiyor musunuz?"
                                    data-confirm-button="Reddet"
                                    data-confirm-type="warning">
                                Reddet
                            </button>
                        </form>
                    }

                    <form asp-action="Delete" asp-route-id="@leave.Id" method="post" class="d-inline">
                        <button type="submit"
                                class="btn btn-outline-danger btn-sm"
                                title="İzin kaydını kalıcı olarak sil"
                                data-confirm-title="İzin Kaydını Sil"
                                data-confirm-message="Bu işlem izin kaydını fiziksel olarak siler ve izin bakiyesini etkileyebilir. Devam etmek istiyor musunuz?"
                                data-confirm-button="Kaydı Sil"
                                data-confirm-type="danger">
                            <i class="bi bi-trash3"></i><span>İzin Kaydını Sil</span>
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
