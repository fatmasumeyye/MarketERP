@using Microsoft.AspNetCore.Mvc.Rendering
@model MarketERP.Models.EmployeeShiftScheduleViewModel

@{
    ViewData["Title"] = "Vardiyalar";
    var employees =
        ViewBag.Employees as IEnumerable<SelectListItem>
        ?? Enumerable.Empty<SelectListItem>();
    var dayNames = new[]
    {
        "Pazartesi",
        "Salı",
        "Çarşamba",
        "Perşembe",
        "Cuma",
        "Cumartesi",
        "Pazar"
    };
    var defaultShiftDate =
        DateTime.Today >= Model.WeekStart && DateTime.Today <= Model.WeekEnd
            ? DateTime.Today
            : Model.WeekStart;
}

<style>
    .shift-panel {
        border: 0;
        border-radius: 16px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, .07);
    }

    .schedule-table {
        min-width: 1380px;
        table-layout: fixed;
        font-size: .86rem;
    }

    .schedule-table th,
    .schedule-table td {
        width: 165px;
        padding: .55rem;
        vertical-align: top;
    }

    .schedule-table .employee-column {
        width: 210px;
        position: sticky;
        left: 0;
        z-index: 3;
        background: #fff;
    }

    .schedule-table thead .employee-column {
        background: #f8f9fa;
        z-index: 5;
    }

    .schedule-table .hours-column {
        width: 95px;
        text-align: center;
    }

    .today-column {
        background-color: #fff8db !important;
    }

    .shift-entry {
        border: 1px solid #cbd5e1;
        border-left: 4px solid #0d6efd;
        border-radius: 9px;
        background: #fff;
        padding: .65rem;
    }

    .shift-entry + .shift-entry {
        margin-top: .4rem;
    }

    .shift-entry.leave-entry {
        border-left-color: #7c3aed;
        background: #f5f3ff;
    }

    .shift-time {
        margin-top: .2rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
    }

    .shift-description {
        display: block;
        margin-top: .2rem;
        color: #64748b;
        font-size: .74rem;
        overflow-wrap: anywhere;
    }

    .empty-shift {
        min-height: 58px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
    }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h2 class="mb-1">@(Model.IsOwnShiftView ? "Vardiyalarım" : "Haftalık Vardiya Çizelgesi")</h2>
        <div class="fs-5 fw-semibold text-primary">
            @Model.WeekStart.ToString("dd.MM.yyyy") - @Model.WeekEnd.ToString("dd.MM.yyyy")
            Haftalık Vardiya Planı
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2">
        @if (Model.CanManageShifts)
        {
            <div class="dropdown">
                <button class="btn btn-success dropdown-toggle"
                        type="button"
                        id="weeklyPlanDownloadDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">
                    Haftalık Planı İndir
                </button>
                <ul class="dropdown-menu" aria-labelledby="weeklyPlanDownloadDropdown">
                    <li>
                        <a class="dropdown-item"
                           asp-action="ExportWeeklyExcel"
                           asp-route-weekStart="@Model.WeekStart.ToString("yyyy-MM-dd")">
                            Excel (.xlsx)
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item"
                           asp-action="ExportWeeklyCsv"
                           asp-route-weekStart="@Model.WeekStart.ToString("yyyy-MM-dd")">
                            CSV (.csv)
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item"
                           asp-action="ExportWeeklyWord"
                           asp-route-weekStart="@Model.WeekStart.ToString("yyyy-MM-dd")">
                            Word (.doc)
                        </a>
                    </li>
                </ul>
            </div>
        }
        <div class="btn-group" role="group" aria-label="Hafta seçimi">
            <a asp-action="Index"
               asp-route-weekStart="@Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary">
                Önceki Hafta
            </a>
            <a asp-action="Index" class="btn btn-outline-primary">Bu Hafta</a>
            <a asp-action="Index"
               asp-route-weekStart="@Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary">
                Sonraki Hafta
            </a>
        </div>
    </div>
</div>

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-4">
    <div class="col-sm-auto">
        <label class="form-label fw-semibold">Görüntülenecek haftayı seç</label>
        <input type="date"
               name="weekStart"
               value="@Model.WeekStart.ToString("yyyy-MM-dd")"
               class="form-control" />
    </div>
    <div class="col-sm-auto">
        <button type="submit" class="btn btn-primary">Seçili Haftayı Göster</button>
    </div>
</form>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info">@TempData["Info"]</div>
}

@if (Model.CanManageShifts)
{
    <div class="alert alert-primary border-0 shadow-sm">
        Bu ekranda haftalık vardiya planını hazırlayabilirsiniz. Boş hücrelerden
        <strong>Şift Ata</strong> diyerek hızlıca vardiya atayabilir, var olan
        vardiyaları düzenleyebilir veya silebilirsiniz.
    </div>
}
else
{
    <div class="alert alert-info border-0 shadow-sm">
        Bu ekranda seçili haftaya ait vardiya planınızı görüntüleyebilirsiniz.
    </div>
}

@if (Model.CanManageShifts)
{
    <div class="card shift-panel mb-4">
        <div class="card-header bg-white"><div class="fw-semibold">Toplu Vardiya Ata</div><small class="text-muted">Aynı gün vardiyası veya onaylı izni bulunan çalışanlar otomatik olarak atlanır.</small></div>
        <div class="card-body"><form asp-action="BulkAdd" method="post"><input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" /><div class="row g-3 align-items-end"><div class="col-lg-4"><label class="form-label">Çalışanlar</label><select name="employeeIds" class="form-select" asp-items="employees" multiple size="5" required></select><small class="text-muted">Birden fazla seçim için Ctrl/Cmd tuşunu kullanın.</small></div><div class="col-md-3 col-lg-2"><label class="form-label">Gün</label><input type="date" name="shiftDate" value="@defaultShiftDate.ToString("yyyy-MM-dd")" class="form-control" required /></div><div class="col-md-4 col-lg-3"><label class="form-label">Vardiya tipi</label><select name="shiftType" class="form-select" required>@foreach(var shiftType in Model.ShiftTypes.Where(x => !x.IsEmpty)){var text=string.IsNullOrWhiteSpace(shiftType.TimeRange)?shiftType.Label:$"{shiftType.Label} ({shiftType.TimeRange})";<option value="@shiftType.Value">@text</option>}</select></div><div class="col-md-3 col-lg-2"><label class="form-label">Açıklama</label><input name="note" class="form-control" maxlength="250" /></div><div class="col-lg-1"><button class="btn btn-primary w-100" title="Toplu ata"><i class="bi bi-people"></i></button></div></div></form></div>
    </div>

    <div class="card shift-panel mb-4" id="addShiftPanel">
        <div class="card-header bg-white">
            <div class="fw-semibold">Haftalık Plana Vardiya Ata</div>
            <small class="text-muted">
                Çalışan, tarih ve şift tipini seçip Kaydet'e bastığınızda vardiya
                veritabanına kaydedilir.
            </small>
        </div>
        <div class="card-body">
            <form asp-action="Add" method="post">
                <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                <div class="row g-3 align-items-end">
                    <div class="col-md-6 col-xl-3">
                        <label class="form-label">Çalışan</label>
                        <select id="addEmployeeId"
                                name="employeeId"
                                class="form-select"
                                asp-items="employees"
                                required>
                            <option value="">Çalışan seçin</option>
                        </select>
                    </div>
                    <div class="col-md-6 col-xl-2">
                        <label class="form-label">Vardiya tarihi</label>
                        <input id="addShiftDate"
                               type="date"
                               name="shiftDate"
                               value="@defaultShiftDate.ToString("yyyy-MM-dd")"
                               class="form-control"
                               required />
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <label class="form-label">Şift tipi</label>
                        <select id="addShiftType" name="shiftType" class="form-select" required>
                            @foreach (var shiftType in Model.ShiftTypes)
                            {
                                var optionText = string.IsNullOrWhiteSpace(shiftType.TimeRange)
                                    ? shiftType.Label
                                    : $"{shiftType.Label} ({shiftType.TimeRange})";
                                <option value="@shiftType.Value">@optionText</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 col-xl-2">
                        <label class="form-label">Ek açıklama</label>
                        <input type="text"
                               name="note"
                               class="form-control"
                               maxlength="250"
                               placeholder="İsteğe bağlı" />
                    </div>
                    <div class="col-md-6 col-xl-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Vardiyayı Kaydet
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

<div class="card shift-panel">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Haftalık Plan</span>
        <span class="badge bg-secondary">@Model.Rows.Count çalışan</span>
    </div>
    <div class="table-responsive">
        <table class="table table-bordered schedule-table mb-0">
            <thead class="table-light">
                <tr>
                    <th class="employee-column">Çalışan</th>
                    @for (var dayIndex = 0; dayIndex < Model.WeekDays.Count; dayIndex++)
                    {
                        var day = Model.WeekDays[dayIndex];
                        var isToday = day == DateTime.Today;

                        <th class="text-center @(isToday ? "today-column" : "")">
                            <div>@dayNames[dayIndex]</div>
                            <small class="text-muted">@day.ToString("dd.MM")</small>
                            @if (isToday)
                            {
                                <span class="badge bg-warning text-dark ms-1">Bugün</span>
                            }
                        </th>
                    }
                    <th class="hours-column">Toplam</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Any())
                {
                    foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td class="employee-column">
                                <div class="fw-semibold">@row.EmployeeName</div>
                                <small class="text-muted">@row.Position</small>
                            </td>
                            @foreach (var day in Model.WeekDays)
                            {
                                var dayShifts = row.ShiftsByDay[day];
                                var isToday = day == DateTime.Today;

                                <td class="@(isToday ? "today-column" : "")">
                                    @if (dayShifts.Any())
                                    {
                                        foreach (var shift in dayShifts)
                                        {
                                            <div class="shift-entry @(shift.IsLeave ? "leave-entry" : "")">
                                                <span class="badge @(shift.IsLeave ? "erp-shift-leave-badge" : "bg-primary")">
                                                    @shift.ShiftLabel
                                                </span>
                                                @if (!shift.IsLeave)
                                                {
                                                    <div class="shift-time">
                                                        @shift.StartTime.ToString(@"hh\:mm")
                                                        -
                                                        @shift.EndTime.ToString(@"hh\:mm")
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(shift.Note))
                                                {
                                                    <small class="shift-description">@shift.Note</small>
                                                }
                                                @if (Model.CanManageShifts)
                                                {
                                                    <div class="d-flex gap-1 mt-2">
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-primary py-0 edit-shift-button"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#editShiftModal"
                                                                data-id="@shift.Id"
                                                                data-employee-id="@shift.EmployeeId"
                                                                data-employee-name="@row.EmployeeName"
                                                                data-date="@shift.ShiftDate.ToString("yyyy-MM-dd")"
                                                                data-shift-type="@shift.ShiftTypeValue"
                                                                data-note="@shift.Note">
                                                            Düzenle
                                                        </button>
                                                        <form asp-action="Delete"
                                                              method="post"
                                                              data-confirm-title="Vardiyayı Kaldır"
                                                              data-confirm-message="Bu vardiya atamasını haftalık plandan kaldırmak istiyor musunuz?"
                                                              data-confirm-button="Vardiyayı Kaldır"
                                                              data-confirm-type="warning">
                                                            <input type="hidden" name="id" value="@shift.Id" />
                                                            <input type="hidden"
                                                                   name="weekStart"
                                                                   value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                                            <button type="submit"
                                                                    class="btn btn-sm btn-outline-danger py-0"
                                                                    title="Vardiya atamasını haftalık plandan kaldır">
                                                                Vardiyayı Kaldır
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-shift">
                                            @if (Model.CanManageShifts)
                                            {
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-secondary add-cell-shift"
                                                        data-employee-id="@row.EmployeeId"
                                                        data-date="@day.ToString("yyyy-MM-dd")">
                                                    Şift Ata
                                                </button>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </div>
                                    }
                                </td>
                            }
                            <td class="hours-column align-middle">
                                <strong>@row.WeeklyHours.ToString("N1")</strong>
                                <small class="d-block text-muted">saat</small>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-5">
                            Bu hafta için görüntülenecek çalışan bulunmuyor.
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.CanManageShifts && Model.Rows.Any())
            {
                <tfoot class="table-light">
                    <tr>
                        <th class="employee-column">Planlanan çalışan</th>
                        @foreach (var day in Model.WeekDays)
                        {
                            <th class="text-center @(day == DateTime.Today ? "today-column" : "")">
                                @Model.DailyEmployeeCounts[day]
                            </th>
                        }
                        <th class="hours-column">-</th>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>

@if (Model.CanManageShifts)
{
    <div class="modal fade" id="editShiftModal" tabindex="-1" aria-labelledby="editShiftModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                    <div class="modal-header">
                        <h5 class="modal-title" id="editShiftModalLabel">Vardiyayı Düzenle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="editShiftId" name="id" />
                        <input type="hidden" id="editEmployeeId" name="employeeId" />
                        <input type="hidden" id="editShiftDate" name="shiftDate" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Çalışan</label>
                                <div class="erp-readonly-field">
                                    <i class="bi bi-person"></i>
                                    <span id="editEmployeeName">-</span>
                                    <i class="bi bi-lock-fill erp-field-lock"></i>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Vardiya tarihi</label>
                                <div class="erp-readonly-field">
                                    <i class="bi bi-calendar3"></i>
                                    <span id="editShiftDateDisplay">-</span>
                                    <i class="bi bi-lock-fill erp-field-lock"></i>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Şift tipi</label>
                                <select id="editShiftType"
                                        name="shiftType"
                                        class="form-select"
                                        required>
                                    @foreach (var shiftType in Model.ShiftTypes)
                                    {
                                        var optionText = string.IsNullOrWhiteSpace(shiftType.TimeRange)
                                            ? shiftType.Label
                                            : $"{shiftType.Label} ({shiftType.TimeRange})";
                                        <option value="@shiftType.Value">@optionText</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ek açıklama</label>
                                <input id="editNote"
                                       type="text"
                                       name="note"
                                       maxlength="250"
                                       class="form-control"
                                       placeholder="İsteğe bağlı" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (Model.CanManageShifts)
    {
        <script>
            document.querySelectorAll('.edit-shift-button').forEach(button => {
                button.addEventListener('click', () => {
                    document.getElementById('editShiftId').value = button.dataset.id;
                    document.getElementById('editEmployeeId').value = button.dataset.employeeId;
                    document.getElementById('editShiftDate').value = button.dataset.date;
                    document.getElementById('editEmployeeName').textContent = button.dataset.employeeName || '-';
                    const dateParts = (button.dataset.date || '').split('-');
                    document.getElementById('editShiftDateDisplay').textContent = dateParts.length === 3
                        ? `${dateParts[2]}.${dateParts[1]}.${dateParts[0]}`
                        : '-';
                    document.getElementById('editShiftType').value = button.dataset.shiftType || 'Sabah';
                    document.getElementById('editNote').value = button.dataset.note || '';
                });
            });

            document.querySelectorAll('.add-cell-shift').forEach(button => {
                button.addEventListener('click', () => {
                    document.getElementById('addEmployeeId').value = button.dataset.employeeId;
                    document.getElementById('addShiftDate').value = button.dataset.date;
                    document.getElementById('addShiftPanel').scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                    window.setTimeout(() => {
                        document.getElementById('addShiftType').focus();
                    }, 350);
                });
            });
        </script>
    }
}
