@model MarketERP.Models.EmployeeDetailViewModel
@{ ViewData["Title"]="Çalışan Detayı"; var e=Model.Employee; }
<div class="erp-page-header"><div><span class="erp-page-eyebrow">PERSONEL KARTI</span><h2>@e.FullName</h2><p>İletişim, izin ve vardiya özeti.</p></div><div class="erp-page-actions"><a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Düzenle</a><a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a></div></div>
<div class="row g-3 mb-4"><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">İzin Talepleri</div><div class="erp-kpi-value">@Model.TotalLeaveRequests</div></div></div><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Onaylı İzin</div><div class="erp-kpi-value">@Model.ApprovedLeaveDays gün</div></div></div><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Toplam Vardiya</div><div class="erp-kpi-value">@Model.TotalShifts</div></div></div><div class="col-md-3"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Vardiya Saati</div><div class="erp-kpi-value">@Model.TotalShiftHours.ToString("0.#")</div></div></div></div>
<div class="card"><div class="card-header"><h3 class="erp-card-title">Personel Bilgileri</h3></div><div class="card-body"><div class="row g-4"><div class="col-md-4"><strong>Telefon</strong><div>@(string.IsNullOrWhiteSpace(e.Phone)?"Tanımlanmadı":e.Phone)</div></div><div class="col-md-4"><strong>E-posta</strong><div>@(string.IsNullOrWhiteSpace(e.Email)?"Tanımlanmadı":e.Email)</div></div><div class="col-md-4"><strong>İşe Giriş</strong><div>@(e.HireDate?.ToString("dd.MM.yyyy")??"Tanımlanmadı")</div></div><div class="col-md-4"><strong>Departman</strong><div>Tanımlanmadı</div></div><div class="col-md-4"><strong>Pozisyon</strong><div>@(string.IsNullOrWhiteSpace(e.Position)?"Tanımlanmadı":e.Position)</div></div><div class="col-md-4"><strong>Durum</strong><div><span class="badge @(e.IsActive?"bg-success":"bg-secondary")">@(e.IsActive?"Aktif":"Pasif")</span></div></div><div class="col-12"><strong>Sonraki Vardiya</strong><div>@(Model.NextShift == null?"Tanımlanmadı":$"{Model.NextShift.ShiftDate:dd.MM.yyyy} · {Model.NextShift.StartTime:hh\\:mm}-{Model.NextShift.EndTime:hh\\:mm}")</div></div></div></div></div>
