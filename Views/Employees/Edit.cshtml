@model MarketERP.Models.Employee
@{ ViewData["Title"]="Çalışan Düzenle"; }
<div class="erp-page-header"><div><span class="erp-page-eyebrow">PERSONEL</span><h2>Çalışan Düzenle</h2><p>Maaş bilgisi yalnızca bu yönetim ekranında gösterilir.</p></div><div class="erp-page-actions"><a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Vazgeç</a></div></div>
<div class="card"><div class="card-body"><form asp-action="Edit" method="post"><input asp-for="Id" type="hidden" /><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="row g-3"><div class="col-md-6"><label asp-for="FullName" class="form-label">Ad Soyad</label><input asp-for="FullName" class="form-control" /></div><div class="col-md-3"><label asp-for="Phone" class="form-label">Telefon</label><input asp-for="Phone" class="form-control" /></div><div class="col-md-3"><label asp-for="Email" class="form-label">E-posta</label><input asp-for="Email" class="form-control" /></div><div class="col-md-4"><label asp-for="Position" class="form-label">Pozisyon</label><input asp-for="Position" class="form-control" /></div><div class="col-md-4"><label asp-for="HireDate" class="form-label">İşe Giriş</label><input asp-for="HireDate" type="date" class="form-control" /></div><div class="col-md-4"><label asp-for="Salary" class="form-label">Maaş</label><input asp-for="Salary" class="form-control" /></div><div class="col-12"><button class="btn btn-primary">Kaydet</button></div></div></form></div></div>
