@model List<MarketERP.Models.Employee>

@{
    ViewData["Title"] = "Çalışan Yönetimi";
}

<h2 class="mb-4">Çalışan Yönetimi</h2>

<form asp-action="Add" method="post" class="mb-4">
    <div class="row mb-2">
        <div class="col-md-3">
            <input type="text" name="FullName" class="form-control" placeholder="Ad Soyad" required />
        </div>

        <div class="col-md-2">
            <input type="text" name="Phone" class="form-control" placeholder="Telefon" />
        </div>

        <div class="col-md-2">
            <input type="text" name="Position" class="form-control" placeholder="Pozisyon" />
        </div>

        <div class="col-md-2">
            <input type="number" step="0.01" name="Salary" class="form-control" placeholder="Maaş" />
        </div>

        <div class="col-md-2">
            <input type="date" name="HireDate" class="form-control" />
        </div>

        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">Ekle</button>
        </div>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Ad Soyad</th>
            <th>Telefon</th>
            <th>Pozisyon</th>
            <th>Maaş</th>
            <th>İşe Giriş</th>
            <th>İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.FullName</td>
                <td>@employee.Phone</td>
                <td>@employee.Position</td>
                <td>@employee.Salary ₺</td>
                <td>@employee.HireDate?.ToString("dd.MM.yyyy")</td>
                <td>
                    <a href="/Employees/Delete/@employee.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>