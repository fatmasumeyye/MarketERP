@model List<MarketERP.Models.Employee>

@using MarketERP.Helpers
@{
    ViewData["Title"] = "Çalışan Yönetimi";
    var status = ViewBag.Status as string ?? "active";
    var canManageEmployee = Context.HasPermission("employee.manage");
}

<div class="erp-page-header">
    <div><span class="erp-page-eyebrow">PERSONEL</span><h2>Çalışan Yönetimi</h2><p>Çalışan ana kayıtlarını ve istihdam bilgilerini yönetin.</p></div>
</div>

<form method="get" class="erp-filter-bar mb-3"><label for="status" class="form-label mb-0">Durum</label><select id="status" name="status" class="form-select" style="max-width:220px"><option value="active" selected="@(status == "active")">Aktif</option><option value="inactive" selected="@(status == "inactive")">Pasif</option><option value="all" selected="@(status == "all")">Tümü</option></select><button type="submit" class="btn btn-outline-primary">Filtrele</button></form>

@if (canManageEmployee)
{
<form asp-action="Add" method="post" class="mb-4">
    <div class="row mb-2">
        <div class="col-md-3">
            <input type="text" name="FullName" class="form-control" placeholder="Ad Soyad" required />
        </div>

        <div class="col-md-2">
            <input type="text" name="Phone" class="form-control" placeholder="Telefon" />
        </div>

        <div class="col-md-2">
            <input type="text" name="Position" class="form-control" placeholder="Pozisyon" />
        </div>

        <div class="col-md-4">
            <input type="date" name="HireDate" class="form-control" />
        </div>

        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">Ekle</button>
        </div>
    </div>
</form>
}

<div class="table-responsive"><table class="table table-bordered table-striped align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Ad Soyad</th>
            <th>Telefon</th>
            <th>Pozisyon</th>
            <th>İşe Giriş</th>
            <th>Durum</th><th>İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr class="@(!employee.IsActive ? "erp-inactive-row" : null)">
                <td>@employee.Id</td>
                <td>@employee.FullName</td>
                <td>@(string.IsNullOrWhiteSpace(employee.Phone) ? "—" : employee.Phone)</td>
                <td>@(string.IsNullOrWhiteSpace(employee.Position) ? "—" : employee.Position)</td>
                <td>@(employee.HireDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                <td><span class="badge @(employee.IsActive ? "bg-success" : "bg-secondary")">@(employee.IsActive ? "Aktif" : "Pasif")</span></td><td>
                    <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-outline-secondary btn-sm" title="Detay"><i class="bi bi-eye"></i></a>
                    @if (canManageEmployee) { <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-outline-primary btn-sm" title="Düzenle"><i class="bi bi-pencil"></i></a> }
                    @if (canManageEmployee && employee.IsActive)
                    {
                    <form asp-action="Delete" asp-route-id="@employee.Id" method="post" class="d-inline"
                          data-confirm-title="Çalışanı Pasif Yap"
                          data-confirm-message="Çalışan yeni atamalarda seçilemeyecek; geçmiş kayıtları korunacaktır."
                          data-confirm-button="Pasif Yap"
                          data-confirm-type="warning">
                        <button type="submit" class="btn btn-outline-warning btn-sm"><i class="bi bi-pause-circle"></i><span>Pasif Yap</span>
                        </button>
                    </form>
                    }
                    else if (canManageEmployee)
                    {
                    <form asp-action="Activate" asp-route-id="@employee.Id" method="post" class="d-inline" data-confirm-title="Çalışanı Aktifleştir" data-confirm-message="Çalışan yeniden atamalarda kullanılabilir olacaktır." data-confirm-button="Aktifleştir" data-confirm-type="success"><button type="submit" class="btn btn-outline-success btn-sm"><i class="bi bi-play-circle"></i><span>Aktifleştir</span></button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table></div>
