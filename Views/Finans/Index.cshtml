@model MarketERP.Models.FinansIndexViewModel
@{ ViewData["Title"] = "Finans Özeti"; }

<div class="erp-page-header">
    <div><span class="erp-page-eyebrow">FİNANS YÖNETİMİ</span><h2>Finans Özeti</h2><p>Bu ayın gerçekleşmiş gelir ve gider görünümünü takip edin.</p></div>
    <div class="erp-page-actions"><a asp-action="HareketEkle" class="btn btn-primary">Hareket Ekle</a><a asp-action="SabitGiderEkle" class="btn btn-outline-primary">Sabit Gider Tanımla</a></div>
</div>
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3"><div class="card erp-kpi-card erp-kpi-success h-100"><div class="card-body"><i class="bi bi-graph-up-arrow"></i><small>Bu Ay Toplam Gelir</small><strong class="text-success">@Model.BuAyToplamGelir.ToString("N2") ₺</strong></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card erp-kpi-card erp-kpi-danger h-100"><div class="card-body"><i class="bi bi-graph-down-arrow"></i><small>Bu Ay Toplam Gider</small><strong class="text-danger">@Model.BuAyToplamGider.ToString("N2") ₺</strong></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card erp-kpi-card @(Model.BuAyNetDurum >= 0 ? "erp-kpi-primary" : "erp-kpi-danger") h-100"><div class="card-body"><i class="bi bi-wallet2"></i><small>Bu Ay Net Durum</small><strong>@Model.BuAyNetDurum.ToString("N2") ₺</strong></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card erp-kpi-card erp-kpi-warning h-100"><div class="card-body"><i class="bi bi-clock-history"></i><small>Gider Takibi</small><strong>@Model.BekleyenGiderSayisi bekleyen</strong><span>@Model.GecikenGiderSayisi geciken kayıt</span></div></div></div>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between"><strong>Son Finans Hareketleri</strong><a asp-action="Hareketler" class="btn btn-sm btn-outline-secondary">Tümünü Gör</a></div>
    <div class="table-responsive"><table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th>Tarih</th><th>Tip</th><th>Kategori</th><th>Başlık</th><th>Durum</th><th class="text-end">Tutar</th></tr></thead>
        <tbody>
        @if (Model.SonHareketler.Count == 0) { <tr><td colspan="6" class="text-center text-muted py-4">Henüz finans hareketi bulunmuyor.</td></tr> }
        else { @foreach (var item in Model.SonHareketler) { <tr><td>@item.Tarih.ToString("dd.MM.yyyy")</td><td><span class="badge @(item.Tip == "Gelir" ? "bg-success" : "bg-danger")">@item.Tip</span></td><td>@item.Kategori</td><td>@item.Baslik</td><td>@item.Durum</td><td class="text-end fw-semibold">@item.Tutar.ToString("N2") ₺</td></tr> } }
        </tbody>
    </table></div>
</div>
