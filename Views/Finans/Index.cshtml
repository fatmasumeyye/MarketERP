@model MarketERP.Models.FinansIndexViewModel
@{ ViewData["Title"] = "Finans Özeti"; }

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div><h2 class="mb-1">Finans Özeti</h2><p class="text-muted mb-0">Bu ayın gerçekleşmiş gelir ve gider görünümü.</p></div>
    <div class="d-flex gap-2"><a asp-action="HareketEkle" class="btn btn-primary">Hareket Ekle</a><a asp-action="SabitGiderEkle" class="btn btn-outline-primary">Sabit Gider Tanımla</a></div>
</div>
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3"><div class="card h-100 border-0 shadow-sm border-start border-success border-4"><div class="card-body"><small class="text-muted">Bu Ay Toplam Gelir</small><div class="fs-4 fw-bold text-success mt-2">@Model.BuAyToplamGelir.ToString("N2") ₺</div></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card h-100 border-0 shadow-sm border-start border-danger border-4"><div class="card-body"><small class="text-muted">Bu Ay Toplam Gider</small><div class="fs-4 fw-bold text-danger mt-2">@Model.BuAyToplamGider.ToString("N2") ₺</div></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card h-100 border-0 shadow-sm border-start @(Model.BuAyNetDurum >= 0 ? "border-primary" : "border-danger") border-4"><div class="card-body"><small class="text-muted">Bu Ay Net Durum</small><div class="fs-4 fw-bold mt-2">@Model.BuAyNetDurum.ToString("N2") ₺</div></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card h-100 border-0 shadow-sm"><div class="card-body"><small class="text-muted">Gider Takibi</small><div class="mt-2"><span class="badge bg-warning text-dark">@Model.BekleyenGiderSayisi bekleyen</span></div><div class="mt-2"><span class="badge bg-danger">@Model.GecikenGiderSayisi geciken</span></div></div></div></div>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between"><strong>Son Finans Hareketleri</strong><a asp-action="Hareketler" class="btn btn-sm btn-outline-secondary">Tümünü Gör</a></div>
    <div class="table-responsive"><table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th>Tarih</th><th>Tip</th><th>Kategori</th><th>Başlık</th><th>Durum</th><th class="text-end">Tutar</th></tr></thead>
        <tbody>
        @if (Model.SonHareketler.Count == 0) { <tr><td colspan="6" class="text-center text-muted py-4">Henüz finans hareketi bulunmuyor.</td></tr> }
        else { @foreach (var item in Model.SonHareketler) { <tr><td>@item.Tarih.ToString("dd.MM.yyyy")</td><td><span class="badge @(item.Tip == "Gelir" ? "bg-success" : "bg-danger")">@item.Tip</span></td><td>@item.Kategori</td><td>@item.Baslik</td><td>@item.Durum</td><td class="text-end fw-semibold">@item.Tutar.ToString("N2") ₺</td></tr> } }
        </tbody>
    </table></div>
</div>
