@model List<MarketERP.Models.SabitGider>
@using System.Globalization
@{ ViewData["Title"]="Sabit Giderler"; var trCulture = CultureInfo.GetCultureInfo("tr-TR"); var titleTextInfo = trCulture.TextInfo; var schedules = ViewBag.ScheduleInfo as Dictionary<int, MarketERP.Models.SabitGiderScheduleViewModel> ?? []; }
<div class="erp-page-header"><div><span class="erp-page-eyebrow">FİNANS YÖNETİMİ</span><h2>Sabit Giderler</h2><p>Tekrarlanan gider kurallarını tek noktadan yönetin.</p></div><div class="erp-page-actions"><a asp-action="SabitGiderEkle" class="btn btn-primary">Sabit Gider Tanımla</a></div></div>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
<thead class="table-light"><tr><th>Gider</th><th>Kategori</th><th>Tekrar</th><th>Ödeme Günü</th><th>Bu Ay</th><th>Son Hareket</th><th>Sonraki Tarih</th><th>Durum</th><th class="text-end">Tutar</th><th></th></tr></thead>
<tbody>
@if(Model.Count==0){<tr><td colspan="10" class="text-center text-muted py-4">Sabit gider tanımı bulunmuyor.</td></tr>}
else{@foreach(var x in Model){schedules.TryGetValue(x.Id,out var schedule);<tr><td><strong>@titleTextInfo.ToTitleCase(x.GiderAdi.ToLower(trCulture))</strong><div class="small text-muted">@(string.IsNullOrWhiteSpace(x.Aciklama) ? "—" : x.Aciklama)</div></td><td>@x.Kategori</td><td>@x.TekrarTipi</td><td>@x.OdemeGunu</td><td><span class="badge @(schedule?.ProcessedThisMonth==true?"bg-success":"bg-warning text-dark")">@(schedule?.ProcessedThisMonth==true?"İşlendi":"Bekliyor")</span></td><td>@(schedule?.LastMovement is null?"Tanımlanmadı":$"FIN-{schedule.LastMovement.Id:000000} · {schedule.LastMovement.Tarih:dd.MM.yyyy}")</td><td>@(schedule?.NextDateLabel??"Tanımlanmadı")</td><td><span class="badge @(x.AktifMi ? "bg-success" : "bg-secondary")">@(x.AktifMi ? "Aktif" : "Devre Dışı")</span></td><td class="text-end text-nowrap fw-semibold">@x.Tutar.ToString("N2") ₺</td><td class="text-end text-nowrap"><a asp-action="HareketEkle" asp-route-sabitGiderId="@x.Id" class="btn btn-sm btn-outline-primary">Hareket Oluştur</a> <form asp-action="SabitGiderDurumDegistir" asp-route-id="@x.Id" method="post" class="d-inline" data-confirm-title="Sabit Gider Durumunu Değiştir" data-confirm-message="Bu sabit gider tanımının aktiflik durumunu değiştirmek istiyor musunuz?" data-confirm-button="Durumu Değiştir" data-confirm-type="warning"><button type="submit" class="btn btn-sm btn-outline-secondary">@(x.AktifMi ? "Devre Dışı Bırak" : "Aktifleştir")</button></form></td></tr>}}
</tbody></table></div></div>
