@model List<MarketERP.Models.SabitGider>
@{ ViewData["Title"]="Sabit Giderler"; }
<div class="d-flex justify-content-between mb-4"><div><h2>Sabit Giderler</h2><p class="text-muted">Tekrarlanan gider kurallarıdır; finans hareketi değildir.</p></div><a asp-action="SabitGiderEkle" class="btn btn-primary">Sabit Gider Tanımla</a></div>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
<thead class="table-light"><tr><th>Gider</th><th>Kategori</th><th>Tekrar</th><th>Ödeme Günü</th><th>Dönem</th><th>Durum</th><th class="text-end">Tutar</th><th></th></tr></thead>
<tbody>
@if(Model.Count==0){<tr><td colspan="8" class="text-center text-muted py-4">Sabit gider tanımı bulunmuyor.</td></tr>}
else{@foreach(var x in Model){<tr><td><strong>@x.GiderAdi</strong><div class="small text-muted">@x.Aciklama</div></td><td>@x.Kategori</td><td>@x.TekrarTipi</td><td>@x.OdemeGunu</td><td>@x.BaslangicTarihi.ToString("dd.MM.yyyy") - @(x.BitisTarihi?.ToString("dd.MM.yyyy") ?? "Süresiz")</td><td><span class="badge @(x.AktifMi ? "bg-success" : "bg-secondary")">@(x.AktifMi ? "Aktif" : "Pasif")</span></td><td class="text-end">@x.Tutar.ToString("N2") ₺</td><td class="text-end"><a asp-action="HareketEkle" asp-route-sabitGiderId="@x.Id" class="btn btn-sm btn-outline-primary">Hareket Oluştur</a> <form asp-action="SabitGiderDurumDegistir" asp-route-id="@x.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-secondary">@(x.AktifMi ? "Pasifleştir" : "Aktifleştir")</button></form></td></tr>}}
</tbody></table></div></div>
