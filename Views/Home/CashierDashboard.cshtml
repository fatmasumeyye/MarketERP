@{
    ViewData["Title"] = "Kasiyer Dashboard";
    var lastSale = ViewBag.LastSale as MarketERP.Models.Sale;
}

<style>
    .cashier-card {
        border: none;
        border-radius: 18px;
        color: white;
        padding: 10px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.10);
        transition: 0.3s;
    }

    .cashier-card:hover {
        transform: translateY(-3px);
    }

    .cashier-card h5 {
        font-size: 14px;
        opacity: 0.9;
        font-weight: 500;
    }

    .cashier-card h2 {
        font-size: 32px;
        margin-top: 10px;
        font-weight: bold;
    }

    .bg-card-blue {
        background: linear-gradient(135deg, #1f3b73, #355c9a);
    }

    .bg-card-green {
        background: linear-gradient(135deg, #1b4332, #2d6a4f);
    }

    .bg-card-orange {
        background: linear-gradient(135deg, #9a6700, #ca8a04);
    }

    .bg-card-gray {
        background: linear-gradient(135deg, #374151, #4b5563);
    }

    .quick-action-card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 4px 14px rgba(0,0,0,0.08);
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 15px;
    }
</style>

<h2 class="mb-2">Kasiyer Dashboard</h2>

<p class="text-muted mb-4">
    Hoş geldin, <strong>@ViewBag.FullName</strong>. Bu ekran sadece senin bugünkü kasa işlemlerini gösterir.
</p>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card cashier-card bg-card-blue mb-3">
            <div class="card-body">
                <h5>Bugünkü Satış Sayım</h5>
                <h2>@ViewBag.TodaySaleCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card cashier-card bg-card-green mb-3">
            <div class="card-body">
                <h5>Bugünkü Satış Toplamım</h5>
                <h2>@ViewBag.TodayTotal ₺</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card cashier-card bg-card-orange mb-3">
            <div class="card-body">
                <h5>Ortalama Satış Tutarım</h5>
                <h2>@ViewBag.AverageSaleAmount ₺</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card cashier-card bg-card-gray mb-3">
            <div class="card-body">
                <h5>Son Satışım</h5>

                @if (lastSale != null)
                {
                    <h2>@lastSale.TotalAmount ₺</h2>
                }
                else
                {
                    <h2>Yok</h2>
                }
            </div>
        </div>
    </div>
</div>

<h4 class="section-title">Hızlı İşlemler</h4>

<div class="row mb-5">
    <div class="col-md-3">
        <div class="card quick-action-card p-3 mb-3">
            <h5>Perakende Satış</h5>
            <p class="text-muted">Barkod okut, ürün ekle ve satışı tamamla.</p>
            <a href="/Sales/Retail" class="btn btn-primary w-100">
                Satışa Git
            </a>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card quick-action-card p-3 mb-3">
            <h5>Kendi Satışlarım</h5>
            <p class="text-muted">Bugünkü ve geçmiş kendi satışlarını görüntüle.</p>
            <button class="btn btn-secondary w-100" disabled>
                Yakında
            </button>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card quick-action-card p-3 mb-3">
            <h5>İade Talebi</h5>
            <p class="text-muted">Satış fişi üzerinden iade talebi oluştur.</p>
            <button class="btn btn-secondary w-100" disabled>
                Yakında
            </button>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card quick-action-card p-3 mb-3">
            <h5>Kasa Kapanışı</h5>
            <p class="text-muted">Kendi kasa kapanışını gün sonunda gönder.</p>
            <button class="btn btn-secondary w-100" disabled>
                Yakında
            </button>
        </div>
    </div>
</div>

<h4 class="section-title">Son Satışlarım</h4>

<div class="card shadow-sm border-0" style="border-radius:18px;">
    <div class="card-body">
        @if (ViewBag.LastMySales == null || ViewBag.LastMySales.Count == 0)
        {
            <div class="alert alert-warning mb-0">
                Henüz sana ait satış kaydı bulunmuyor.
            </div>
        }
        else
        {
            <table class="table table-bordered table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Satış ID</th>
                        <th>Müşteri</th>
                        <th>Toplam Tutar</th>
                        <th>Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var sale in ViewBag.LastMySales)
                    {
                        <tr>
                            <td>@sale.Id</td>
                            <td>@sale.Customer?.FullName</td>
                            <td>@sale.TotalAmount ₺</td>
                            <td>@sale.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <a href="/Sales/Invoice/@sale.Id"
                                       class="btn btn-info btn-sm">
                                    Fatura
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>