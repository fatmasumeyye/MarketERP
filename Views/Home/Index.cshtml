@using MarketERP.Models
@using MarketERP.Helpers
@{
    ViewData["Title"] = "Dashboard";

    var isStoreManager = (bool?)ViewBag.IsStoreManager == true;
    var lowStockProducts = ViewBag.LowStockProducts as List<Product> ?? new List<Product>();
    var recentSales = ViewBag.RecentSales as List<Sale> ?? new List<Sale>();
    var topProductLabels = ViewBag.TopProductLabels as List<string> ?? new List<string>();
    var topProductData = ViewBag.TopProductData as List<int> ?? new List<int>();
}

<style>
    .dashboard-card {
        display: block;
        min-height: 126px;
        border: 0;
        border-radius: 16px;
        color: #fff;
        text-decoration: none;
        box-shadow: 0 6px 18px rgba(0, 0, 0, .1);
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .dashboard-card:hover {
        color: #fff;
        transform: translateY(-3px);
        box-shadow: 0 10px 24px rgba(0, 0, 0, .14);
    }

    .dashboard-card h2 {
        font-size: 1.75rem;
        font-weight: 700;
    }

    .dashboard-panel {
        border: 0;
        border-radius: 16px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, .07);
    }

    .bg-card-blue { background: linear-gradient(135deg, #1f3b73, #355c9a); }
    .bg-card-green { background: linear-gradient(135deg, #1b4332, #2d6a4f); }
    .bg-card-orange { background: linear-gradient(135deg, #9a6700, #ca8a04); }
    .bg-card-red { background: linear-gradient(135deg, #7f1d1d, #b91c1c); }
    .bg-card-gray { background: linear-gradient(135deg, #374151, #4b5563); }
    .bg-card-purple { background: linear-gradient(135deg, #4c1d95, #7c3aed); }
    .bg-card-teal { background: linear-gradient(135deg, #115e59, #0f766e); }
</style>

<div class="mb-4">
    <h2 class="mb-1">@(isStoreManager ? "Mağaza Müdürü Dashboard" : "Admin Dashboard")</h2>
    <p class="text-muted mb-0">
        @(isStoreManager
            ? "Günlük mağaza operasyonları ve onay bekleyen işlemler"
            : "Satış, stok ve yönetim işlemlerinin genel özeti")
    </p>
</div>

<div class="card dashboard-panel mb-4">
    <div class="card-header bg-white"><span class="fw-semibold">Hızlı İşlemler</span></div>
    <div class="card-body d-flex flex-wrap gap-2">
        @if (Context.HasPermission("sale.retail.create")) { <a asp-controller="Sales" asp-action="Retail" class="btn btn-primary"><i class="bi bi-cart-plus"></i> Yeni Satış</a> }
        @if (Context.HasPermission("product.create")) { <a asp-controller="Products" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-box-seam"></i> Yeni Ürün</a> }
        @if (Context.HasPermission("customer.create")) { <a asp-controller="Customers" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-person-plus"></i> Yeni Müşteri</a> }
        @if (Context.HasPermission("purchase.create")) { <a asp-controller="PurchaseOrders" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-bag-plus"></i> Yeni Sipariş</a> }
        @if (Context.HasPermission("supplier.manage")) { <a asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-truck"></i> Yeni Tedarikçi</a> }
        @if (Context.HasPermission("employee.manage")) { <a asp-controller="Employees" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-person-badge"></i> Yeni Personel</a> }
        @if (Context.HasPermission("role.manage") && Context.HasPermission("finance.view")) { <a asp-controller="Finans" asp-action="HareketEkle" class="btn btn-outline-primary"><i class="bi bi-cash-stack"></i> Yeni Finans Hareketi</a> }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sales" asp-action="Index" asp-route-dateFilter="today"
           class="card dashboard-card bg-card-green">
            <div class="card-body">
                <div>Bugünkü Satış Tutarı</div>
                <h2 class="mt-2 mb-0">@(((decimal)ViewBag.TodayRevenue).ToString("N2")) ₺</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sales" asp-action="Index" asp-route-dateFilter="today"
           class="card dashboard-card bg-card-blue">
            <div class="card-body">
                <div>Bugünkü Satış Adedi</div>
                <h2 class="mt-2 mb-0">@ViewBag.TodaySalesCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Returns" asp-action="Index" asp-route-status="Beklemede"
           class="card dashboard-card bg-card-red">
            <div class="card-body">
                <div>Bekleyen İade Talepleri</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingReturnRequestsCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="CashRegister" asp-action="Index" asp-route-status="Beklemede"
           class="card dashboard-card bg-card-purple">
            <div class="card-body">
                <div>Bekleyen Kasa Kapanışları</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingCashClosingCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="WholesaleSales" asp-action="Index" asp-route-status="Onay Bekliyor"
           class="card dashboard-card bg-card-orange">
            <div class="card-body">
                <div>Bekleyen Toptan Talepler</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingWholesaleRequestCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Products" asp-action="Index" asp-route-stockStatus="critical"
           class="card dashboard-card bg-card-orange">
            <div class="card-body">
                <div>Kritik Stoktaki Ürünler</div>
                <h2 class="mt-2 mb-0">@ViewBag.CriticalStockCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Products" asp-action="Index" asp-route-stockStatus="out"
           class="card dashboard-card bg-card-red">
            <div class="card-body">
                <div>Stokta Biten Ürünler</div>
                <h2 class="mt-2 mb-0">@ViewBag.OutOfStockCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="EmployeeLeaves" asp-action="Index"
           class="card dashboard-card bg-card-teal">
            <div class="card-body">
                <div>Bekleyen İzin Talepleri</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingLeavesCount</h2>
            </div>
        </a>
    </div>

    @if (!isStoreManager)
    {
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Sales" asp-action="Index" asp-route-dateFilter="week"
               class="card dashboard-card bg-card-gray">
                <div class="card-body">
                    <div>Haftalık Ciro</div>
                    <h2 class="mt-2 mb-0">@(((decimal)ViewBag.WeeklyRevenue).ToString("N2")) ₺</h2>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Sales" asp-action="Index" asp-route-dateFilter="month"
               class="card dashboard-card bg-card-purple">
                <div class="card-body">
                    <div>Aylık Ciro</div>
                    <h2 class="mt-2 mb-0">@(((decimal)ViewBag.MonthlyRevenue).ToString("N2")) ₺</h2>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Sales" asp-action="Index" asp-route-dateFilter="year"
               class="card dashboard-card bg-card-teal">
                <div class="card-body">
                    <div>Yıllık Ciro</div>
                    <h2 class="mt-2 mb-0">@(((decimal)ViewBag.YearlyRevenue).ToString("N2")) ₺</h2>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Products" asp-action="Index" class="card dashboard-card bg-card-gray">
                <div class="card-body">
                    <div>Toplam Ürün</div>
                    <h2 class="mt-2 mb-0">@ViewBag.ProductCount</h2>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="SupportTickets" asp-action="Index"
               class="card dashboard-card bg-card-purple">
                <div class="card-body">
                    <div>Bekleyen Destek Talepleri</div>
                    <h2 class="mt-2 mb-0">@ViewBag.PendingSupportTicketsCount</h2>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="EmployeeBonuses" asp-action="Index"
               class="card dashboard-card bg-card-orange">
                <div class="card-body">
                    <div>Prim Kayıtları</div>
                    <h2 class="mt-2 mb-0">@ViewBag.PendingBonusesCount</h2>
                </div>
            </a>
        </div>
    }
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card dashboard-panel h-100">
            <div class="card-header bg-white fw-semibold">Bugünün En Çok Satan Ürünleri</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Ürün</th><th class="text-end">Satılan Adet</th></tr>
                    </thead>
                    <tbody>
                        @if (topProductLabels.Any())
                        {
                            for (var i = 0; i < topProductLabels.Count; i++)
                            {
                                <tr>
                                    <td>@topProductLabels[i]</td>
                                    <td class="text-end">@(i < topProductData.Count ? topProductData[i] : 0)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="2" class="text-center text-muted py-4">Bugün henüz satış yapılmadı.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card dashboard-panel h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Kritik Stok Durumu</span>
                <a asp-controller="Products" asp-action="Index" asp-route-stockStatus="critical"
                   class="btn btn-sm btn-outline-danger">Tümünü Gör</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Ürün</th><th class="text-end">Stok</th><th class="text-end">Kritik Seviye</th></tr>
                    </thead>
                    <tbody>
                        @if (lowStockProducts.Any())
                        {
                            foreach (var product in lowStockProducts)
                            {
                                <tr>
                                    <td>@product.Name</td>
                                    <td class="text-end"><span class="badge bg-danger">@product.StockQuantity</span></td>
                                    <td class="text-end">@product.CriticalStock</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">Kritik stokta ürün bulunmuyor.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card dashboard-panel mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Son Satışlar</span>
        <a asp-controller="Sales" asp-action="Index" class="btn btn-sm btn-outline-primary">Satış Listesi</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Satış No</th><th>Müşteri</th><th>Tutar</th><th>Ödeme</th><th>Tarih</th><th></th></tr>
            </thead>
            <tbody>
                @if (recentSales.Any())
                {
                    foreach (var sale in recentSales)
                    {
                        <tr>
                            <td>#@sale.Id</td>
                            <td>@(sale.Customer?.FullName ?? "Nihai Tüketici")</td>
                            <td>@sale.TotalAmount.ToString("N2") ₺</td>
                            <td>@(string.IsNullOrWhiteSpace(sale.PaymentType) ? "-" : sale.PaymentType)</td>
                            <td>@sale.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                <a asp-controller="Sales" asp-action="Invoice" asp-route-id="@sale.Id"
                                   class="btn btn-sm btn-outline-info">Fatura</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Satış kaydı bulunmuyor.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!isStoreManager)
{
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card dashboard-panel p-4 h-100">
                <h5>Son 7 Günlük Ciro</h5>
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card dashboard-panel p-4 h-100">
                <h5>Son 7 Günlük Satış Adedi</h5>
                <canvas id="salesCountChart"></canvas>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card dashboard-panel p-4 h-100">
                <h5>Bu Ay Ödeme Tipi Dağılımı</h5>
                <canvas id="paymentTypeChart"></canvas>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card dashboard-panel p-4 h-100">
                <h5>Bugünün En Çok Satan Ürünleri</h5>
                <canvas id="topProductsChart"></canvas>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (!isStoreManager)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            new Chart(document.getElementById('revenueChart'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.RevenueChartLabels)),
                    datasets: [{ label: 'Ciro', data: @Html.Raw(Json.Serialize(ViewBag.RevenueChartData)), tension: .35 }]
                }
            });

            new Chart(document.getElementById('salesCountChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.RevenueChartLabels)),
                    datasets: [{ label: 'Satış Adedi', data: @Html.Raw(Json.Serialize(ViewBag.SalesCountChartData)) }]
                }
            });

            new Chart(document.getElementById('paymentTypeChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.PaymentTypeLabels)),
                    datasets: [{ data: @Html.Raw(Json.Serialize(ViewBag.PaymentTypeData)) }]
                }
            });

            new Chart(document.getElementById('topProductsChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.TopProductLabels)),
                    datasets: [{ label: 'Satılan Adet', data: @Html.Raw(Json.Serialize(ViewBag.TopProductData)) }]
                },
                options: { indexAxis: 'y' }
            });
        </script>
    }
}
