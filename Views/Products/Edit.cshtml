@model MarketERP.Models.Product

@{
    ViewData["Title"] = "Ürün Düzenle";
}

<h2 class="mb-4">Ürün Düzenle</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Barkod</label>
        <input asp-for="Barcode" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label>Ürün Adı</label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Kategori</label>
        <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories">
            <option value="">Kategori seçiniz</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Tedarikçi</label>
        <select asp-for="SupplierId" class="form-control" asp-items="ViewBag.Suppliers">
            <option value="">Tedarikçi seçiniz</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Stok</label>
        <input asp-for="StockQuantity" class="form-control" type="number" required />
    </div>

    <div class="mb-3">
        <label>Alış Fiyatı</label>
        <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" required />
    </div>

    <div class="mb-3">
        <label>Satış Fiyatı</label>
        <input asp-for="SalePrice" class="form-control" type="number" step="0.01" required />
    </div>

    <div class="mb-3">
        <label>Kritik Stok</label>
        <input asp-for="CriticalStock" class="form-control" type="number" required />
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a href="/Products" class="btn btn-secondary">Geri Dön</a>
</form>