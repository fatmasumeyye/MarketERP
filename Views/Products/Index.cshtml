@model List<MarketERP.Models.Product>
@using MarketERP.Helpers

@{
    ViewData["Title"] = "Ürün Yönetimi";

    var productIdsUsedInSales = ViewBag.ProductIdsUsedInSales as List<int> ?? new List<int>();
    var mainCategories = ViewBag.MainCategories as List<MarketERP.Models.Category> ?? new List<MarketERP.Models.Category>();

    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    int? selectedSupplierId = ViewBag.SelectedSupplierId as int?;

    string selectedCategoryName = ViewBag.SelectedCategoryName ?? "Tüm Ürünler";
    string search = ViewBag.Search ?? "";
    string stockStatus = ViewBag.StockStatus ?? "";
    string recordStatus = ViewBag.RecordStatus ?? "active";
    var canUpdateProduct = Context.HasPermission("product.update");
    var canDeactivateProduct = Context.HasPermission("product.delete");
    var canAdjustStock = Context.HasPermission("stock.adjust");
    var canManageProduct = canUpdateProduct || canDeactivateProduct || canAdjustStock;
    var canCreateProduct = Context.HasPermission("product.create");
    var canCreatePurchase = Context.HasPermission("purchase.create");

    var isWholesaleStaff =
        Context.HasPermission("sale.wholesale.create")
        && !Context.HasPermission("role.manage")
        && !Context.HasPermission("user.manage")
        && !Context.HasPermission("sale.view.all");
}

<style>
    .category-sidebar {
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 12px;
        background: #fff;
        max-height: 680px;
        overflow-y: auto;
    }

    .category-title {
        font-weight: 700;
        margin-bottom: 10px;
        font-size: 16px;
    }

    .category-link {
        display: block;
        padding: 7px 9px;
        border-radius: 6px;
        color: #212529;
        text-decoration: none;
        margin-bottom: 3px;
    }

        .category-link:hover {
            background: #f1f3f5;
            color: #000;
        }

        .category-link.active {
            background: #0d6efd;
            color: #fff;
        }

    .subcategory-link {
        padding-left: 22px;
        font-size: 14px;
    }

    .product-panel {
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 16px;
        background: #fff;
    }

    .selected-category-box {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 10px 12px;
        margin-bottom: 15px;
    }

    .filter-card {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 15px;
    }

    .role-info-box {
        background: #e7f5ff;
        border: 1px solid #a5d8ff;
        color: #0b7285;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 16px;
    }
</style>

<h2 class="mb-4">
    @if (isWholesaleStaff)
    {
        <span>Ürün / Stok Görüntüleme</span>
    }
    else
    {
        <span>Ürün / Stok Yönetimi</span>
    }
</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

@if (isWholesaleStaff)
{
    <div class="role-info-box">
        <strong>Toptan satış rolü:</strong>
        Bu ekranda ürünleri, stok durumunu ve satış fiyatlarını görüntüleyebilirsin.
        Stok ekleme, ürün düzenleme, ürün silme ve sipariş önerisi işlemleri bu rolün görevi değildir.
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex gap-2">
        @if (canCreateProduct)
        {
            <a href="/Products/Create" class="btn btn-primary">
                + Yeni Ürün Ekle
            </a>
        }

        @if (canCreatePurchase)
        {
            <a href="/PurchaseOrders/Suggestions" class="btn btn-outline-danger">
                Kritik Stok Sipariş Önerileri
            </a>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="category-sidebar">
            <div class="category-title">Kategoriler</div>
            <input type="search" id="productCategorySearch" class="form-control form-control-sm mb-2" placeholder="Kategori ara..." />

            <a asp-controller="Products"
                   asp-action="Index"
                   asp-route-supplierId="@selectedSupplierId"
                   asp-route-stockStatus="@stockStatus"
                   asp-route-search="@search"
                   asp-route-recordStatus="@recordStatus"
                   class="category-link @(selectedCategoryId == null ? "active" : "")">
                Tüm Ürünler
            </a>

            @foreach (var main in mainCategories)
            {
                <button type="button" class="btn btn-sm btn-link product-category-toggle p-0" data-category-id="@main.Id" aria-label="Alt kategorileri aç veya kapat"><i class="bi bi-chevron-right"></i></button>
                <a asp-controller="Products"
                       asp-action="Index"
                       asp-route-categoryId="@main.Id"
                       asp-route-supplierId="@selectedSupplierId"
                       asp-route-stockStatus="@stockStatus"
                       asp-route-search="@search"
                       asp-route-recordStatus="@recordStatus"
                       class="category-link @(selectedCategoryId == main.Id ? "active" : "")">
                    @main.Name
                </a>

                @foreach (var sub in main.SubCategories.OrderBy(s => s.Name))
                {
                    <a asp-controller="Products"
                           asp-action="Index"
                           asp-route-categoryId="@sub.Id"
                           asp-route-supplierId="@selectedSupplierId"
                           asp-route-stockStatus="@stockStatus"
                           asp-route-search="@search"
                           asp-route-recordStatus="@recordStatus"
                           data-parent-category="@main.Id"
                           class="category-link subcategory-link product-category-child @(selectedCategoryId == sub.Id ? "active" : "")">
                        @sub.Name
                    </a>
                }
            }
        </div>
    </div>

    <div class="col-md-9">
        <div class="product-panel">

            <div class="selected-category-box">
                <strong>Seçili Kategori:</strong> @selectedCategoryName
                <br />
                <span class="text-muted">Gösterilen ürün sayısı: @Model.Count</span>
            </div>

            <form method="get" class="filter-card">
                @if (selectedCategoryId != null)
                {
                    <input type="hidden" name="categoryId" value="@selectedCategoryId" />
                }

                <div class="row g-2">
                    <div class="col-md-3">
                        <input type="text"
                               name="search"
                               value="@search"
                               class="form-control"
                               placeholder="Ürün adı veya barkod ara..." />
                    </div>

                    <div class="col-md-3">
                        <select name="supplierId" class="form-control" asp-items="ViewBag.Suppliers">
                            <option value="">Tüm tedarikçiler</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <select name="stockStatus" class="form-control">
                            <option value="">Tüm stok durumları</option>

                            @if (stockStatus == "critical")
                            {
                                <option value="critical" selected>Kritik stok</option>
                            }
                            else
                            {
                                <option value="critical">Kritik stok</option>
                            }

                            @if (stockStatus == "low")
                            {
                                <option value="low" selected>Azalıyor</option>
                            }
                            else
                            {
                                <option value="low">Azalıyor</option>
                            }

                            @if (stockStatus == "normal")
                            {
                                <option value="normal" selected>Normal</option>
                            }
                            else
                            {
                                <option value="normal">Normal</option>
                            }

                            @if (stockStatus == "out")
                            {
                                <option value="out" selected>Stokta Yok</option>
                            }
                            else
                            {
                                <option value="out">Stokta Yok</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <select name="recordStatus" class="form-control">
                            <option value="active" selected="@(recordStatus == "active")">Aktif</option>
                            <option value="inactive" selected="@(recordStatus == "inactive")">Pasif</option>
                            <option value="all" selected="@(recordStatus == "all")">Tümü</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn btn-dark w-100">
                            Filtrele
                        </button>
                    </div>
                </div>
            </form>

            <table class="table table-bordered table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Barkod</th>
                        <th class="erp-product-name-column">Ürün</th>
                        <th>Kategori</th>
                        <th>Tedarikçi</th>
                        <th>Stok</th>
                        <th>Alış</th>
                        <th>Satış</th>
                        <th>Durum</th>

                        @if (canManageProduct)
                        {
                        <th>Stok Girişi</th>
                            <th>İşlem</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr class="@(!product.IsActive ? "erp-inactive-row" : null)">
                            <td>@product.Id</td>
                            <td>@product.Barcode</td>
                            <td class="erp-product-name-column"><strong>@product.Name</strong></td>

                            <td>
                                @if (product.Category?.ParentCategory != null)
                                {
                                    <span>
                                        @product.Category.ParentCategory.Name &gt; @product.Category.Name
                                    </span>
                                }
                                else if (product.Category != null)
                                {
                                    <span>@product.Category.Name</span>
                                }
                                else
                                {
                                    <span class="text-danger">Kategori eksik</span>
                                }
                            </td>

                            <td>@product.Supplier?.CompanyName</td>
                            <td>@product.StockQuantity</td>
                            <td>@product.PurchasePrice.ToString("N2") ₺</td>
                            <td>@product.SalePrice.ToString("N2") ₺</td>

                            <td>
                                @if (!product.IsActive)
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                                else if (product.StockQuantity <= 0)
                                {
                                    <span class="badge bg-danger" title="Ürünün kullanılabilir stoğu bulunmuyor.">Stokta Yok</span>
                                }
                                else if (product.StockQuantity <= product.CriticalStock)
                                {
                                    <span class="badge bg-warning text-dark" title="Ürün kritik stok seviyesinde veya altında.">Kritik</span>
                                }
                                else if (product.StockQuantity <= product.CriticalStock + 5)
                                {
                                    <span class="badge bg-info text-dark" title="Stok seviyesi kritik sınıra yaklaşıyor.">Azalıyor</span>
                                }
                                else
                                {
                                    <span class="badge bg-success" title="Stok seviyesi normal aralıkta.">Normal</span>
                                }
                            </td>

                            @if (canManageProduct)
                            {
                                <td>
                                    @if (product.IsActive && canAdjustStock)
                                    {
                                    <form asp-action="AddStock" method="post" class="d-flex gap-1">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="number"
                                               name="quantity"
                                               class="form-control form-control-sm"
                                               placeholder="+Stok"
                                               min="1"
                                               required />
                                        <button type="submit" class="btn btn-success btn-sm" title="Girilen miktarı mevcut stoğa ekle">
                                            Stok Girişi
                                        </button>
                                    </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>

                                <td>
                                    @if (product.IsActive)
                                    {
                                    @if (canUpdateProduct)
                                    {
                                    <a href="/Products/Edit/@product.Id" class="btn btn-warning btn-sm">
                                        Düzenle
                                    </a>
                                    }
                                    @if (canDeactivateProduct)
                                    {
                                        <form asp-action="Delete" asp-route-id="@product.Id" method="post" class="d-inline"
                                              data-confirm-title="Ürünü Pasif Yap"
                                              data-confirm-message="Ürün yeni satış ve satın alma işlemlerinde seçilemeyecek; geçmiş kayıtları korunacaktır."
                                              data-confirm-button="Pasif Yap"
                                              data-confirm-type="warning">
                                            <button type="submit" class="btn btn-outline-warning btn-sm">
                                                <i class="bi bi-pause-circle"></i><span>Pasif Yap</span>
                                            </button>
                                        </form>
                                    }
                                    }
                                    else if (canDeactivateProduct)
                                    {
                                        <form asp-action="Activate" asp-route-id="@product.Id" method="post" class="d-inline" data-confirm-title="Ürünü Aktifleştir" data-confirm-message="Ürün yeniden yeni işlemlerde kullanılabilecektir." data-confirm-button="Aktifleştir" data-confirm-type="success"><button type="submit" class="btn btn-outline-success btn-sm"><i class="bi bi-play-circle"></i><span>Aktifleştir</span></button></form>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.product-category-toggle').forEach(function (button) {
        button.addEventListener('click', function () {
            const children = document.querySelectorAll('.product-category-child[data-parent-category="' + button.dataset.categoryId + '"]');
            const hide = Array.from(children).some(x => x.style.display !== 'none');
            children.forEach(x => x.style.display = hide ? 'none' : 'block');
            button.classList.toggle('is-collapsed', hide);
        });
    });
    const search = document.getElementById('productCategorySearch');
    search?.addEventListener('input', function () {
        const term = search.value.toLocaleLowerCase('tr-TR').trim();
        document.querySelectorAll('.category-link').forEach(link => link.style.display = !term || link.textContent.toLocaleLowerCase('tr-TR').includes(term) ? 'block' : 'none');
    });
});
</script>
