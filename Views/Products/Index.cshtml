@model List<MarketERP.Models.Product>
@using MarketERP.Helpers

@{
    ViewData["Title"] = "Ürün Yönetimi";

    var productIdsUsedInSales = ViewBag.ProductIdsUsedInSales as List<int> ?? new List<int>();
    var mainCategories = ViewBag.MainCategories as List<MarketERP.Models.Category> ?? new List<MarketERP.Models.Category>();

    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    int? selectedSupplierId = ViewBag.SelectedSupplierId as int?;

    string selectedCategoryName = ViewBag.SelectedCategoryName ?? "Tüm Ürünler";
    string search = ViewBag.Search ?? "";
    string stockStatus = ViewBag.StockStatus ?? "";

    var isWholesaleStaff =
        Context.HasPermission("sale.wholesale.create")
        && !Context.HasPermission("role.manage")
        && !Context.HasPermission("user.manage")
        && !Context.HasPermission("sale.view.all");
}

<style>
    .category-sidebar {
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 12px;
        background: #fff;
        max-height: 680px;
        overflow-y: auto;
    }

    .category-title {
        font-weight: 700;
        margin-bottom: 10px;
        font-size: 16px;
    }

    .category-link {
        display: block;
        padding: 7px 9px;
        border-radius: 6px;
        color: #212529;
        text-decoration: none;
        margin-bottom: 3px;
    }

        .category-link:hover {
            background: #f1f3f5;
            color: #000;
        }

        .category-link.active {
            background: #0d6efd;
            color: #fff;
        }

    .subcategory-link {
        padding-left: 22px;
        font-size: 14px;
    }

    .product-panel {
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 16px;
        background: #fff;
    }

    .selected-category-box {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 10px 12px;
        margin-bottom: 15px;
    }

    .filter-card {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 15px;
    }

    .role-info-box {
        background: #e7f5ff;
        border: 1px solid #a5d8ff;
        color: #0b7285;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 16px;
    }
</style>

<h2 class="mb-4">
    @if (isWholesaleStaff)
    {
        <span>Ürün / Stok Görüntüleme</span>
    }
    else
    {
        <span>Ürün / Stok Yönetimi</span>
    }
</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

@if (isWholesaleStaff)
{
    <div class="role-info-box">
        <strong>Toptan satış rolü:</strong>
        Bu ekranda ürünleri, stok durumunu ve satış fiyatlarını görüntüleyebilirsin.
        Stok ekleme, ürün düzenleme, ürün silme ve sipariş önerisi işlemleri bu rolün görevi değildir.
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex gap-2">
        @if (!isWholesaleStaff)
        {
            <a href="/Products/Create" class="btn btn-primary">
                + Yeni Ürün Ekle
            </a>

            <a href="/PurchaseOrders/Suggestions" class="btn btn-outline-danger">
                Kritik Stok Sipariş Önerileri
            </a>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="category-sidebar">
            <div class="category-title">Kategoriler</div>

            <a asp-controller="Products"
                   asp-action="Index"
                   asp-route-supplierId="@selectedSupplierId"
                   asp-route-stockStatus="@stockStatus"
                   asp-route-search="@search"
                   class="category-link @(selectedCategoryId == null ? "active" : "")">
                Tüm Ürünler
            </a>

            @foreach (var main in mainCategories)
            {
                <a asp-controller="Products"
                       asp-action="Index"
                       asp-route-categoryId="@main.Id"
                       asp-route-supplierId="@selectedSupplierId"
                       asp-route-stockStatus="@stockStatus"
                       asp-route-search="@search"
                       class="category-link @(selectedCategoryId == main.Id ? "active" : "")">
                    @main.Name
                </a>

                @foreach (var sub in main.SubCategories.OrderBy(s => s.Name))
                {
                    <a asp-controller="Products"
                           asp-action="Index"
                           asp-route-categoryId="@sub.Id"
                           asp-route-supplierId="@selectedSupplierId"
                           asp-route-stockStatus="@stockStatus"
                           asp-route-search="@search"
                           class="category-link subcategory-link @(selectedCategoryId == sub.Id ? "active" : "")">
                        @sub.Name
                    </a>
                }
            }
        </div>
    </div>

    <div class="col-md-9">
        <div class="product-panel">

            <div class="selected-category-box">
                <strong>Seçili Kategori:</strong> @selectedCategoryName
                <br />
                <span class="text-muted">Gösterilen ürün sayısı: @Model.Count</span>
            </div>

            <form method="get" class="filter-card">
                @if (selectedCategoryId != null)
                {
                    <input type="hidden" name="categoryId" value="@selectedCategoryId" />
                }

                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="text"
                               name="search"
                               value="@search"
                               class="form-control"
                               placeholder="Ürün adı veya barkod ara..." />
                    </div>

                    <div class="col-md-3">
                        <select name="supplierId" class="form-control" asp-items="ViewBag.Suppliers">
                            <option value="">Tüm tedarikçiler</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <select name="stockStatus" class="form-control">
                            <option value="">Tüm stok durumları</option>

                            @if (stockStatus == "critical")
                            {
                                <option value="critical" selected>Kritik stok</option>
                            }
                            else
                            {
                                <option value="critical">Kritik stok</option>
                            }

                            @if (stockStatus == "low")
                            {
                                <option value="low" selected>Azalıyor</option>
                            }
                            else
                            {
                                <option value="low">Azalıyor</option>
                            }

                            @if (stockStatus == "normal")
                            {
                                <option value="normal" selected>Normal</option>
                            }
                            else
                            {
                                <option value="normal">Normal</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn btn-dark w-100">
                            Filtrele
                        </button>
                    </div>
                </div>
            </form>

            <table class="table table-bordered table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Barkod</th>
                        <th>Ürün</th>
                        <th>Kategori</th>
                        <th>Tedarikçi</th>
                        <th>Stok</th>
                        <th>Alış</th>
                        <th>Satış</th>
                        <th>Durum</th>

                        @if (!isWholesaleStaff)
                        {
                            <th>Stok Ekle</th>
                            <th>İşlem</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>@product.Id</td>
                            <td>@product.Barcode</td>
                            <td>@product.Name</td>

                            <td>
                                @if (product.Category?.ParentCategory != null)
                                {
                                    <span>
                                        @product.Category.ParentCategory.Name &gt; @product.Category.Name
                                    </span>
                                }
                                else if (product.Category != null)
                                {
                                    <span>@product.Category.Name</span>
                                }
                                else
                                {
                                    <span class="text-danger">Kategori eksik</span>
                                }
                            </td>

                            <td>@product.Supplier?.CompanyName</td>
                            <td>@product.StockQuantity</td>
                            <td>@product.PurchasePrice.ToString("N2") ₺</td>
                            <td>@product.SalePrice.ToString("N2") ₺</td>

                            <td>
                                @if (product.StockQuantity <= product.CriticalStock)
                                {
                                    <span class="badge bg-danger">Kritik</span>
                                }
                                else if (product.StockQuantity <= product.CriticalStock + 5)
                                {
                                    <span class="badge bg-warning text-dark">Azalıyor</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Normal</span>
                                }
                            </td>

                            @if (!isWholesaleStaff)
                            {
                                <td>
                                    <form asp-action="AddStock" method="post" class="d-flex gap-1">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="number"
                                               name="quantity"
                                               class="form-control form-control-sm"
                                               placeholder="+Stok"
                                               min="1"
                                               required />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            Ekle
                                        </button>
                                    </form>
                                </td>

                                <td>
                                    <a href="/Products/Edit/@product.Id" class="btn btn-warning btn-sm">
                                        Düzenle
                                    </a>

                                    @if (productIdsUsedInSales.Contains(product.Id))
                                    {
                                        <button class="btn btn-secondary btn-sm"
                                                disabled
                                                title="Bu ürün satış geçmişinde kullanıldığı için silinemez.">
                                            Silinemez
                                        </button>
                                    }
                                    else
                                    {
                                        <a href="/Products/Delete/@product.Id"
                                               class="btn btn-danger btn-sm"
                                data-confirm-message="Bu ürünü silmek istediğinize emin misiniz?">
                                            Sil
                                        </a>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>