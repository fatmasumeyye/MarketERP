@model List<MarketERP.Models.Product>

@{
    ViewData["Title"] = "Ürün Yönetimi";
}

<h2 class="mb-4">Ürün / Stok Yönetimi</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="search" class="form-control" placeholder="Ürün ara..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-dark w-100">Ara</button>
        </div>
    </div>
</form>

<form asp-action="Add" method="post" class="mb-4">
    <div class="row mb-2">
        <div class="col-md-3">
            <input type="text" name="Barcode" class="form-control" placeholder="Barkod" required />
        </div>

        <div class="col-md-3">
            <input type="text" name="Name" class="form-control" placeholder="Ürün adı" required />
        </div>

        <div class="col-md-3">
            <select name="CategoryId" class="form-control" asp-items="ViewBag.Categories">
                <option value="">Kategori seçiniz</option>
            </select>
        </div>

        <div class="col-md-3">
            <select name="SupplierId" class="form-control" asp-items="ViewBag.Suppliers">
                <option value="">Tedarikçi seçiniz</option>
            </select>
        </div>
    </div>

    <div class="row mb-2">
        <div class="col-md-3">
            <input type="number" name="StockQuantity" class="form-control" placeholder="Stok" required />
        </div>

        <div class="col-md-3">
            <input type="number" step="0.01" name="PurchasePrice" class="form-control" placeholder="Alış fiyatı" required />
        </div>

        <div class="col-md-3">
            <input type="number" step="0.01" name="SalePrice" class="form-control" placeholder="Satış fiyatı" required />
        </div>

        <div class="col-md-3">
            <input type="number" name="CriticalStock" class="form-control" placeholder="Kritik stok" value="5" required />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Ürün Ekle</button>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Barkod</th>
            <th>Ürün</th>
            <th>Kategori</th>
            <th>Tedarikçi</th>
            <th>Stok</th>
            <th>Alış</th>
            <th>Satış</th>
            <th>Durum</th>
            <th>Stok Ekle</th>
            <th>İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Barcode</td>
                <td>@product.Name</td>
                <td>@product.Category?.Name</td>
                <td>@product.Supplier?.CompanyName</td>
                <td>@product.StockQuantity</td>
                <td>@product.PurchasePrice ₺</td>
                <td>@product.SalePrice ₺</td>

                <td>
                    @if (product.StockQuantity <= product.CriticalStock)
                    {
                        <span class="badge bg-danger">Kritik</span>
                    }
                    else if (product.StockQuantity <= product.CriticalStock + 5)
                    {
                        <span class="badge bg-warning text-dark">Azalıyor</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Normal</span>
                    }
                </td>

                <td>
                    <form asp-action="AddStock" method="post" class="d-flex gap-1">
                        <input type="hidden" name="productId" value="@product.Id" />
                        <input type="number" name="quantity" class="form-control form-control-sm" placeholder="+Stok" min="1" required />
                        <button type="submit" class="btn btn-success btn-sm">Ekle</button>
                    </form>
                </td>

                <td>
                    <a href="/Products/Edit/@product.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a href="/Products/Delete/@product.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>