@model MarketERP.Models.ProjectBudgetViewModel

@{
    ViewData["Title"] = "Proje Bütçesi";
    var net = Model.Project.Income - Model.Project.Expense;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div><h2 class="mb-1">Proje Bütçesi ve İş Yükü</h2><p class="text-muted mb-0">@Model.Project.Name finansal proje özeti</p></div>
    <a asp-action="Index" class="btn btn-outline-secondary">Proje Dashboardu</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3"><div class="card h-100 shadow-sm border-0"><div class="card-body"><small class="text-muted">Toplam Bütçe</small><div class="fs-4 fw-bold">@Model.Project.Budget.ToString("N2") ₺</div></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card h-100 shadow-sm border-0"><div class="card-body"><small class="text-muted">Toplam Gelir</small><div class="fs-4 fw-bold text-success">@Model.Project.Income.ToString("N2") ₺</div></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card h-100 shadow-sm border-0"><div class="card-body"><small class="text-muted">Toplam Gider</small><div class="fs-4 fw-bold text-danger">@Model.Project.Expense.ToString("N2") ₺</div></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="card h-100 shadow-sm border-0 border-start @(net >= 0 ? "border-success" : "border-danger") border-4"><div class="card-body"><small class="text-muted">Net Durum</small><div class="fs-4 fw-bold @(net >= 0 ? "text-success" : "text-danger")">@net.ToString("N2") ₺</div></div></div></div>
</div>

<div class="row g-4">
    <div class="col-xl-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white"><strong>Görev Bazlı Bütçe ve Maliyet</strong></div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0"><thead class="table-light"><tr><th>Görev</th><th>Sorumlu</th><th class="text-end">Bütçe</th><th class="text-end">Maliyet</th><th class="text-end">Fark</th></tr></thead><tbody>
                @foreach (var task in Model.Tasks)
                {
                    var difference = task.Budget - task.Cost;
                    <tr><td>@task.Title</td><td>@(task.AssignedMember?.FullName ?? "Atanmadı")</td><td class="text-end">@task.Budget.ToString("N2") ₺</td><td class="text-end">@task.Cost.ToString("N2") ₺</td><td class="text-end @(difference >= 0 ? "text-success" : "text-danger")">@difference.ToString("N2") ₺</td></tr>
                }
                </tbody><tfoot class="table-light fw-bold"><tr><td colspan="2">Toplam</td><td class="text-end">@Model.TotalTaskBudget.ToString("N2") ₺</td><td class="text-end">@Model.TotalTaskCost.ToString("N2") ₺</td><td></td></tr></tfoot></table>
            </div>
        </div>
    </div>
    <div class="col-xl-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white"><strong>Ekip Üyesi Bazlı İş Yükü</strong></div>
            <div class="card-body">
            @foreach (var member in Model.Members)
            {
                var percent = member.EstimatedWorkHours <= 0 ? 0 : Math.Min(100, member.ActualWorkHours / member.EstimatedWorkHours * 100);
                <div class="mb-3"><div class="d-flex justify-content-between small mb-1"><span><strong>@member.FullName</strong> · @member.Role</span><span>@member.ActualWorkHours.ToString("N1") / @member.EstimatedWorkHours.ToString("N1") saat</span></div><div class="progress" style="height:8px"><div class="progress-bar @(percent > 90 ? "bg-warning" : "bg-primary")" style="width:@percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div></div></div>
            }
            </div>
        </div>
    </div>
</div>
