@model MarketERP.Models.ProjectCriticalPathViewModel

@{
    ViewData["Title"] = "Kritik Yol ve Bolluk Süresi";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h2 class="mb-1">Kritik Yol ve Bolluk Süresi</h2>
        <p class="text-muted mb-0">@Model.Project.Name proje zaman planı</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Gantt" class="btn btn-outline-primary">Gantt Şeması</a>
        <a asp-action="Reports" class="btn btn-primary">Raporlar</a>
    </div>
</div>

@if (Model.HasDependencyCycle)
{
    <div class="alert alert-warning">
        Görev bağımlılıklarında döngü tespit edildi. Döngü içeren zincirler kritik yol hesabına dahil edilmedi.
    </div>
}

@if (Model.InvalidTaskCount > 0)
{
    <div class="alert alert-info">
        Tarihleri eksik veya başlangıç tarihi bitiş tarihinden sonra olan @Model.InvalidTaskCount görev hesaplama dışında bırakıldı.
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100 border-start border-danger border-4 shadow-sm">
            <div class="card-body">
                <small class="text-muted">Kritik Görev Sayısı</small>
                <div class="fs-3 fw-bold text-danger">@Model.CriticalTasks.Count</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-start border-primary border-4 shadow-sm">
            <div class="card-body">
                <small class="text-muted">Kritik Yol Takvim Süresi</small>
                <div class="fs-3 fw-bold">@Model.TotalCriticalDurationDays gün</div>
                <div class="small text-muted mt-1">
                    Bu süre, kritik yolun ilk başlangıç tarihi ile tahmini proje bitiş tarihi arasındaki takvim süresidir.
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-start border-success border-4 shadow-sm">
            <div class="card-body">
                <small class="text-muted">Tahmini Proje Bitişi</small>
                <div class="fs-3 fw-bold">@Model.EstimatedFinishDate.ToString("dd.MM.yyyy")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5>Kritik yol nedir?</h5>
                <p class="text-muted mb-0">
                    Görev bağımlılıkları içindeki toplam süresi en uzun zincirdir. Bu zincirdeki bir gecikme,
                    proje bitiş tarihini doğrudan etkileyebilir.
                </p>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5>Bolluk süresi nedir?</h5>
                <p class="text-muted mb-0">
                    Bir görevin proje bitişini veya kendisine bağlı görevin başlangıcını geciktirmeden
                    ertelenebileceği yaklaşık gün sayısıdır.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-danger text-white">
        <strong>Kritik Görev Zinciri</strong>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Sıra</th>
                    <th>Görev</th>
                    <th>Başlangıç</th>
                    <th>Bitiş</th>
                    <th>Süre</th>
                    <th>Sorumlu</th>
                    <th>İlerleme</th>
                    <th>Bolluk</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.CriticalTasks.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Hesaplanabilir kritik görev bulunamadı.</td></tr>
                }
                else
                {
                    @foreach (var row in Model.CriticalTasks)
                    {
                        <tr>
                            <td><span class="badge bg-danger">@row.Sequence</span></td>
                            <td>
                                <strong>@row.Task.Title</strong>
                                <div class="small text-muted">@row.Task.DependsOnTask?.Title</div>
                            </td>
                            <td>@row.Task.StartDate.ToString("dd.MM.yyyy")</td>
                            <td>@row.Task.EndDate.ToString("dd.MM.yyyy")</td>
                            <td>@row.DurationDays gün</td>
                            <td>@(row.Task.AssignedMember?.FullName ?? "Atanmamış")</td>
                            <td style="min-width: 140px;">
                                <div class="progress" style="height: 18px;">
                                    <div class="progress-bar" style="width: @row.Task.ProgressPercent%">%@row.Task.ProgressPercent</div>
                                </div>
                            </td>
                            <td><span class="badge bg-danger">0 gün</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex flex-wrap justify-content-between gap-2">
        <strong>Kritik Olmayan Görevler ve Bolluk Süreleri</strong>
        <small class="text-muted">Bu değerler doğrudan bağımlılık ve proje bitişine göre yaklaşık hesaplanmıştır.</small>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Görev</th>
                    <th>Durum</th>
                    <th>Bitiş</th>
                    <th>Sorumlu</th>
                    <th>Süre</th>
                    <th>Yaklaşık Bolluk</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.NonCriticalTasks.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Kritik yol dışında görev bulunmuyor.</td></tr>
                }
                else
                {
                    @foreach (var row in Model.NonCriticalTasks)
                    {
                        <tr>
                            <td>@row.Task.Title</td>
                            <td><span class="badge bg-secondary">@row.Task.Status</span></td>
                            <td>@row.Task.EndDate.ToString("dd.MM.yyyy")</td>
                            <td>@(row.Task.AssignedMember?.FullName ?? "Atanmamış")</td>
                            <td>@row.DurationDays gün</td>
                            <td><span class="badge bg-info text-dark">@row.SlackDays gün</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
