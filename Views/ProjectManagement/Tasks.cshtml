@model MarketERP.Models.ProjectTasksViewModel

@{
    ViewData["Title"] = "Proje Görevleri";
    var statuses = new[] { "Planlandı", "Devam Ediyor", "Beklemede", "Tamamlandı" };
    var priorities = new[] { "Düşük", "Orta", "Yüksek", "Kritik" };
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div><h2 class="mb-1">Proje Görevleri</h2><p class="text-muted mb-0">İş planı, bağımlılıklar, ilerleme ve maliyet takibi</p></div>
    <a asp-action="Index" class="btn btn-outline-secondary">Proje Dashboardu</a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white"><strong>@(Model.IsEditing ? "Görevi Düzenle" : "Yeni Görev Ekle")</strong></div>
    <div class="card-body">
        <form asp-action="SaveTask" method="post">
            <input asp-for="FormTask.Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="row g-3">
                <div class="col-md-6"><label asp-for="FormTask.Title" class="form-label">Başlık</label><input asp-for="FormTask.Title" class="form-control" /><span asp-validation-for="FormTask.Title" class="text-danger small"></span></div>
                <div class="col-md-3"><label asp-for="FormTask.Status" class="form-label">Durum</label><select asp-for="FormTask.Status" class="form-select">@foreach (var item in statuses) { <option value="@item">@item</option> }</select></div>
                <div class="col-md-3"><label asp-for="FormTask.Priority" class="form-label">Öncelik</label><select asp-for="FormTask.Priority" class="form-select">@foreach (var item in priorities) { <option value="@item">@item</option> }</select></div>
                <div class="col-12"><label asp-for="FormTask.Description" class="form-label">Açıklama</label><textarea asp-for="FormTask.Description" class="form-control" rows="2"></textarea></div>
                <div class="col-md-3"><label asp-for="FormTask.StartDate" class="form-label">Başlangıç</label><input asp-for="FormTask.StartDate" type="date" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="FormTask.EndDate" class="form-label">Bitiş</label><input asp-for="FormTask.EndDate" type="date" class="form-control" /><span asp-validation-for="FormTask.EndDate" class="text-danger small"></span></div>
                <div class="col-md-3"><label asp-for="FormTask.ProgressPercent" class="form-label">İlerleme (%)</label><input asp-for="FormTask.ProgressPercent" class="form-control" min="0" max="100" /></div>
                <div class="col-md-3"><label asp-for="FormTask.SlackDays" class="form-label">Bolluk Süresi (gün)</label><input asp-for="FormTask.SlackDays" class="form-control" min="0" /></div>
                <div class="col-md-4"><label asp-for="FormTask.AssignedMemberId" class="form-label">Sorumlu</label><select asp-for="FormTask.AssignedMemberId" class="form-select"><option value="">Atanmadı</option>@foreach (var member in Model.TeamMembers) { <option value="@member.Id">@member.FullName - @member.Role</option> }</select></div>
                <div class="col-md-4"><label asp-for="FormTask.DependsOnTaskId" class="form-label">Bağımlı Olduğu Görev</label><select asp-for="FormTask.DependsOnTaskId" class="form-select"><option value="">Bağımsız</option>@foreach (var task in Model.Tasks.Where(t => t.Id != Model.FormTask.Id)) { <option value="@task.Id">@task.Title</option> }</select></div>
                <div class="col-md-2"><label asp-for="FormTask.Budget" class="form-label">Bütçe</label><input asp-for="FormTask.Budget" class="form-control" min="0" step="0.01" /></div>
                <div class="col-md-2"><label asp-for="FormTask.Cost" class="form-label">Maliyet</label><input asp-for="FormTask.Cost" class="form-control" min="0" step="0.01" /></div>
                <div class="col-12"><div class="form-check"><input asp-for="FormTask.IsCritical" class="form-check-input" /><label asp-for="FormTask.IsCritical" class="form-check-label">Kritik yol görevi</label></div></div>
            </div>
            <div class="mt-3 d-flex gap-2"><button type="submit" class="btn btn-primary">@(Model.IsEditing ? "Değişiklikleri Kaydet" : "Görevi Ekle")</button>@if (Model.IsEditing) { <a asp-action="Tasks" class="btn btn-outline-secondary">İptal</a> }</div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark"><tr><th>Görev</th><th>Tarih / Süre</th><th>Durum</th><th>İlerleme</th><th>Sorumlu / Bağımlılık</th><th>Bütçe / Maliyet</th><th></th></tr></thead>
            <tbody>
            @foreach (var task in Model.Tasks)
            {
                var delayed = task.ProgressPercent < 100 && task.EndDate.Date < DateTime.Today;
                <tr>
                    <td><div class="fw-semibold">@task.Title @if (task.IsCritical) { <span class="badge bg-danger">Kritik</span> }</div><small class="text-muted">@task.Priority öncelik</small></td>
                    <td><small>@task.StartDate.ToString("dd.MM.yyyy") - @task.EndDate.ToString("dd.MM.yyyy")</small><div class="text-muted">@task.DurationDays gün</div></td>
                    <td><span class="badge @(delayed ? "bg-danger" : task.Status == "Tamamlandı" ? "bg-success" : "bg-primary")">@(delayed ? "Gecikmiş" : task.Status)</span></td>
                    <td style="min-width:130px"><div class="progress" style="height:8px"><div class="progress-bar" style="width:@task.ProgressPercent%"></div></div><small>%@task.ProgressPercent</small></td>
                    <td><small>@(task.AssignedMember?.FullName ?? "Atanmadı")</small><div class="text-muted small">@(task.DependsOnTask?.Title ?? "Bağımsız")</div></td>
                    <td><small>@task.Budget.ToString("N2") ₺</small><div class="text-muted small">@task.Cost.ToString("N2") ₺ maliyet</div></td>
                    <td class="text-nowrap"><a asp-action="Tasks" asp-route-editId="@task.Id" class="btn btn-sm btn-outline-primary">Düzenle</a><form asp-action="DeleteTask" method="post" class="d-inline" data-confirm-title="Görevi Sil" data-confirm-message="Bu proje görevini silmek istediğinize emin misiniz?" data-confirm-button="Sil" data-confirm-type="danger"><input type="hidden" name="id" value="@task.Id" /><button class="btn btn-sm btn-outline-danger" type="submit">Sil</button></form></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
