@model MarketERP.Models.ProjectTeamViewModel

@{
    ViewData["Title"] = "Proje Ekibi";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div><h2 class="mb-1">Proje Ekibi</h2><p class="text-muted mb-0">Tahmini ve gerçekleşen iş yükü takibi</p></div>
    <a asp-action="Index" class="btn btn-outline-secondary">Proje Dashboardu</a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white"><strong>@(Model.IsEditing ? "Ekip Üyesini Düzenle" : "Ekip Üyesi Ekle")</strong></div>
    <div class="card-body">
        <form asp-action="SaveTeamMember" method="post">
            <input asp-for="FormMember.Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="row g-3">
                <div class="col-md-3"><label asp-for="FormMember.FullName" class="form-label">Ad Soyad</label><input asp-for="FormMember.FullName" class="form-control" /><span asp-validation-for="FormMember.FullName" class="text-danger small"></span></div>
                <div class="col-md-3"><label asp-for="FormMember.Role" class="form-label">Projedeki Rol</label><input asp-for="FormMember.Role" class="form-control" /><span asp-validation-for="FormMember.Role" class="text-danger small"></span></div>
                <div class="col-md-3"><label asp-for="FormMember.Email" class="form-label">E-posta</label><input asp-for="FormMember.Email" class="form-control" /><span asp-validation-for="FormMember.Email" class="text-danger small"></span></div>
                <div class="col-md-1"><label asp-for="FormMember.EstimatedWorkHours" class="form-label">Tahmini</label><input asp-for="FormMember.EstimatedWorkHours" class="form-control" min="0" step="0.5" /></div>
                <div class="col-md-2"><label asp-for="FormMember.ActualWorkHours" class="form-label">Gerçekleşen Saat</label><input asp-for="FormMember.ActualWorkHours" class="form-control" min="0" step="0.5" /></div>
            </div>
            <div class="mt-3 d-flex gap-2"><button type="submit" class="btn btn-primary">@(Model.IsEditing ? "Değişiklikleri Kaydet" : "Ekip Üyesini Ekle")</button>@if (Model.IsEditing) { <a asp-action="Team" class="btn btn-outline-secondary">İptal</a> }</div>
        </form>
    </div>
</div>

<div class="row g-3">
@foreach (var member in Model.Members)
{
    var utilization = member.EstimatedWorkHours <= 0 ? 0 : Math.Round(member.ActualWorkHours / member.EstimatedWorkHours * 100, 1);
    <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-2">
                    <div><h5 class="mb-1">@member.FullName</h5><div class="text-primary">@member.Role</div></div>
                    <span class="badge bg-light text-dark align-self-start">%@utilization</span>
                </div>
                <div class="small text-muted mt-2">@member.Email</div>
                <div class="mt-3"><div class="d-flex justify-content-between small"><span>Tahmini</span><strong>@member.EstimatedWorkHours.ToString("N1") saat</strong></div><div class="d-flex justify-content-between small"><span>Gerçekleşen</span><strong>@member.ActualWorkHours.ToString("N1") saat</strong></div></div>
            </div>
            <div class="card-footer bg-white border-0"><a asp-action="Team" asp-route-editId="@member.Id" class="btn btn-sm btn-outline-primary">Düzenle</a><form asp-action="DeleteTeamMember" method="post" class="d-inline" data-confirm-title="Ekip Üyesini Sil" data-confirm-message="Bu ekip üyesini silmek istediğinize emin misiniz? Görev atamaları boş bırakılacaktır." data-confirm-button="Sil" data-confirm-type="danger"><input type="hidden" name="id" value="@member.Id" /><button class="btn btn-sm btn-outline-danger" type="submit">Sil</button></form></div>
        </div>
    </div>
}
</div>
