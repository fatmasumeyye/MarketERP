@model MarketERP.Models.PurchaseOrder
@using MarketERP.Helpers

@{
    ViewData["Title"] = "Sipariş Detayı";
    var canApprovePurchase = Context.HasPermission("purchase.approve");
    var canCancelPurchase = Context.HasPermission("purchase.create") || canApprovePurchase;
    var canReceivePurchase = Context.HasPermission("stock.adjust");
}

<h2 class="mb-4">Satın Alma Sipariş Detayı</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">
        <strong>PO-@Model.Id.ToString("000000")</strong>
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <strong>Tedarikçi:</strong>
                <br />
                @Model.Supplier?.CompanyName
            </div>

            <div class="col-md-3">
                <strong>Tarih:</strong>
                <br />
                @Model.OrderDate.ToString("dd.MM.yyyy HH:mm")
            </div>

            <div class="col-md-3">
                <strong>Toplam:</strong>
                <br />
                @Model.TotalAmount.ToString("N2") ₺
            </div>

            <div class="col-md-3">
                <strong>Durum:</strong>
                <br />

                @if (Model.Status == "Onay Bekliyor")
                {
                    <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                }
                else if (Model.Status == "Onaylandı")
                {
                    <span class="badge bg-primary">Onaylandı</span>
                }
                else if (Model.Status == "Teslim Alındı")
                {
                    <span class="badge bg-success">Teslim Alındı</span>
                }
                else if (Model.Status == "Kısmi Teslim Alındı")
                {
                    <span class="badge bg-info text-dark">Kısmi Teslim Alındı</span>
                }
                else if (Model.Status == "İptal Edildi")
                {
                    <span class="badge bg-secondary">İptal Edildi</span>
                }
                else
                {
                    <span class="badge bg-light text-dark">@Model.Status</span>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Note))
        {
            <hr />
            <strong>Not:</strong>
            <p>@Model.Note</p>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white"><strong>İşlem Geçmişi</strong></div>
    <div class="card-body">
        <div class="erp-timeline">
            <div class="erp-timeline-item is-complete"><span class="erp-timeline-dot"></span><div><strong>Sipariş oluşturuldu</strong><div class="text-muted small">@((Model.CreatedAt == default ? Model.OrderDate : Model.CreatedAt).ToString("dd.MM.yyyy HH:mm"))</div></div></div>
            @if (Model.ApprovedAt.HasValue) { <div class="erp-timeline-item is-complete"><span class="erp-timeline-dot"></span><div><strong>Sipariş onaylandı</strong><div class="text-muted small">@Model.ApprovedAt.Value.ToString("dd.MM.yyyy HH:mm")</div></div></div> }
            @if (Model.CheckedAt.HasValue) { <div class="erp-timeline-item is-complete"><span class="erp-timeline-dot"></span><div><strong>Mal kabul kontrolü yapıldı</strong><div class="text-muted small">@Model.CheckedAt.Value.ToString("dd.MM.yyyy HH:mm")</div></div></div> }
            @if (Model.ReceivedAt.HasValue) { <div class="erp-timeline-item is-complete"><span class="erp-timeline-dot"></span><div><strong>Teslim alındı ve stok güncellendi</strong><div class="text-muted small">@Model.ReceivedAt.Value.ToString("dd.MM.yyyy HH:mm")</div></div></div> }
            @if (Model.Status == "İptal Edildi") { <div class="erp-timeline-item is-cancelled"><span class="erp-timeline-dot"></span><div><strong>Sipariş iptal edildi</strong><div class="text-muted small">Tarih bilgisi mevcut modelde tutulmuyor.</div></div></div> }
        </div>
    </div>
</div>

<form asp-action="Receive" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Ürün</th>
                <th>Sipariş Miktarı</th>
                <th>Gelen Miktar</th>
                <th>Kalan</th>
                <th>Birim Fiyat</th>
                <th>Ara Toplam</th>
                <th>Mevcut Stok</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Items)
            {
                var kalan = item.Quantity - item.ReceivedQuantity;

                <tr>
                    <td>
                        <strong>@item.Product?.Name</strong>
                        <br />
                        <small class="text-muted">Barkod: @item.Product?.Barcode</small>
                    </td>

                    <td>@item.Quantity</td>

                    <td>
                        @if (canReceivePurchase && (Model.Status == "Onaylandı" || Model.Status == "Kısmi Teslim Alındı"))
                        {
                            <input type="number"
                                   name="receivedQuantities[@item.Id]"
                                   value="@item.ReceivedQuantity"
                                   min="0"
                                   max="@item.Quantity"
                                   class="form-control" />
                        }
                        else
                        {
                            <span>@item.ReceivedQuantity</span>
                        }
                    </td>

                    <td>
                        @if (kalan <= 0)
                        {
                            <span class="badge bg-success">Tamamlandı</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@kalan kaldı</span>
                        }
                    </td>

                    <td>@item.UnitPrice.ToString("N2") ₺</td>
                    <td>@item.Subtotal.ToString("N2") ₺</td>
                    <td>@item.Product?.StockQuantity</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between">
        <a href="/PurchaseOrders" class="btn btn-secondary">
            Siparişlere Dön
        </a>

        <div class="d-flex gap-2">
            @if (canApprovePurchase && Model.Status == "Onay Bekliyor")
            {
                <button type="submit"
                        formaction="/PurchaseOrders/Approve/@Model.Id"
                        formmethod="post"
                        class="btn btn-primary"
                                data-confirm-message="Bu siparişi onaylamak istiyor musunuz?">
                    Siparişi Onayla
                </button>
            }

            @if (canCancelPurchase && Model.Status == "Onay Bekliyor")
            {
                <button type="submit"
                        formaction="/PurchaseOrders/Cancel/@Model.Id"
                        formmethod="post"
                        class="btn btn-outline-danger"
                                data-confirm-message="Bu siparişi iptal etmek istiyor musunuz?">
                    İptal Et
                </button>
            }

            @if (canReceivePurchase && (Model.Status == "Onaylandı" || Model.Status == "Kısmi Teslim Alındı"))
            {
                <button type="submit"
                        formaction="/PurchaseOrders/ReceiveAll/@Model.Id"
                        formmethod="post"
                        class="btn btn-success"
                                data-confirm-message="Bu sipariş tam olarak geldi mi? Tüm ürünler sipariş miktarı kadar stoğa eklenecek.">
                    Sipariş Tam Geldi / Stoğa Ekle
                </button>

                <button type="submit"
                        class="btn btn-outline-success"
                                data-confirm-message="Girilen gelen miktarlar stoğa eklensin mi?">
                    Kısmi Teslim Al / Stoğa Ekle
                </button>
            }
        </div>
    </div>
</form>
