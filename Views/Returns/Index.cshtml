@model List<MarketERP.Models.ReturnRequest>

@{
    ViewData["Title"] = "İade Yönetimi";
    var activeStatus = ViewBag.Status as string;

    var groupedRequests = Model
        .GroupBy(r => string.IsNullOrWhiteSpace(r.RequestNo) ? $"RT-{r.Id:D6}" : r.RequestNo)
        .OrderByDescending(g => g.Max(x => x.RequestedAt))
        .ToList();
}

<style>
    .summary-card {
        border: none;
        border-radius: 16px;
        color: white;
        padding: 18px;
        box-shadow: 0 5px 14px rgba(0,0,0,0.12);
        min-height: 105px;
        text-decoration: none;
        display: block;
    }

        .summary-card:hover {
            color: white;
            transform: translateY(-2px);
        }

        .summary-card h6 {
            font-size: 14px;
            opacity: 0.9;
            margin-bottom: 8px;
        }

        .summary-card h3 {
            font-weight: 800;
            margin: 0;
        }

    .bg-blue {
        background: linear-gradient(135deg, #1f3b73, #355c9a);
    }

    .bg-orange {
        background: linear-gradient(135deg, #9a6700, #ca8a04);
    }

    .bg-green {
        background: linear-gradient(135deg, #1b4332, #2d6a4f);
    }

    .bg-red {
        background: linear-gradient(135deg, #7f1d1d, #b91c1c);
    }

    .admin-box {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 22px;
    }

    .return-card {
        border-radius: 16px;
        overflow: hidden;
    }

    .stock-select {
        min-width: 230px;
    }
</style>

<h2 class="mb-4">İade Yönetimi</h2>

<div class="admin-box">
    <strong>Yönetici ekranı:</strong>
    Bu ekranda iade belgelerini belge bazlı görebilir, her ürün için ayrı stok kararı verebilirsiniz.
    Hasarlı/kırık ürünler normal stoğa eklenmez.
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-md-3">
        <a href="/Returns" class="summary-card bg-blue mb-3">
            <h6>Tüm İade Belgeleri</h6>
            <h3>@ViewBag.TotalCount</h3>
        </a>
    </div>

    <div class="col-md-3">
        <a href="/Returns?status=Beklemede" class="summary-card bg-orange mb-3">
            <h6>Bekleyen İadeler</h6>
            <h3>@ViewBag.PendingCount</h3>
        </a>
    </div>

    <div class="col-md-3">
        <a href="/Returns?status=Onaylandı" class="summary-card bg-green mb-3">
            <h6>Onaylanan İadeler</h6>
            <h3>@ViewBag.ApprovedCount</h3>
        </a>
    </div>

    <div class="col-md-3">
        <a href="/Returns?status=Reddedildi" class="summary-card bg-red mb-3">
            <h6>Reddedilen İadeler</h6>
            <h3>@ViewBag.RejectedCount</h3>
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(activeStatus))
{
    <div class="alert alert-info">
        Şu an filtrelenen durum: <strong>@activeStatus</strong>
        <a href="/Returns" class="btn btn-sm btn-outline-primary ms-2">Tümünü Göster</a>
    </div>
}

@if (!groupedRequests.Any())
{
    <div class="alert alert-warning">
        İade talebi bulunmuyor.
    </div>
}
else
{
    foreach (var group in groupedRequests)
    {
        var first = group.First();

        var documentStatus = group.All(x => x.Status == "Onaylandı")
            ? "Onaylandı"
            : group.All(x => x.Status == "Reddedildi")
                ? "Reddedildi"
                : group.Any(x => x.Status == "Beklemede")
                    ? "Beklemede"
                    : "Karışık";

        <div class="card shadow-sm mb-4 return-card">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <div>
                    <strong>İade Belgesi:</strong> @group.Key
                    <span class="ms-3">Satış ID: @first.SaleId</span>
                    <span class="ms-3">Talep Eden: @(first.Employee?.FullName ?? "-")</span>
                    <span class="ms-3">Talep Tarihi: @first.RequestedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </div>

                <div>
                    @if (documentStatus == "Beklemede")
                    {
                        <span class="badge bg-warning text-dark">Beklemede</span>
                    }
                    else if (documentStatus == "Onaylandı")
                    {
                        <span class="badge bg-success">Onaylandı</span>
                    }
                    else if (documentStatus == "Reddedildi")
                    {
                        <span class="badge bg-danger">Reddedildi</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@documentStatus</span>
                    }
                </div>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <a href="/Returns/ReturnInvoice/@first.Id" class="btn btn-info btn-sm">
                        İade Faturası
                    </a>
                </div>

                @if (documentStatus == "Beklemede")
                {
                    <form asp-action="ApproveDocument"
                          method="post"
                          onsubmit="return confirm('Bu iade belgesi onaylanacak. Her ürün için seçilen stok işlemine göre işlem yapılacak. Devam edilsin mi?');">

                        <input type="hidden" name="requestNo" value="@group.Key" />

                        <table class="table table-bordered table-striped align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Ürün</th>
                                    <th>Adet</th>
                                    <th>Sebep</th>
                                    <th>Açıklama</th>
                                    <th>Stok İşlemi</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in group)
                                {
                                    <tr>
                                        <td>@(item.Product?.Name ?? "-")</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.ReasonType</td>
                                        <td>@item.Reason</td>
                                        <td>
                                            <select name="stockAction_@item.Id"
                                                    class="form-control form-control-sm stock-select"
                                                    required>
                                                <option value="">Stok işlemi seç</option>
                                                <option value="Satılabilir stoğa ekle">Satılabilir stoğa ekle</option>
                                                <option value="Hasarlı / fire, stoğa ekleme">Hasarlı / fire, stoğa ekleme</option>
                                                <option value="İnceleme bekliyor, stoğa ekleme">İnceleme bekliyor, stoğa ekleme</option>
                                                <option value="Tedarikçiye iade edilecek, stoğa ekleme">Tedarikçiye iade edilecek, stoğa ekleme</option>
                                            </select>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="row">
                            <div class="col-md-8">
                                <input type="text"
                                       name="reviewNote"
                                       class="form-control"
                                       placeholder="Genel yönetici notu" />
                            </div>

                            <div class="col-md-4 text-end">
                                <button type="submit" class="btn btn-success">
                                    Belgeyi Onayla
                                </button>
                            </div>
                        </div>
                    </form>

                    <form asp-action="RejectDocument"
                          method="post"
                          class="mt-2"
                          onsubmit="return confirm('Bu iade belgesi tamamen reddedilecek. Devam edilsin mi?');">
                        <input type="hidden" name="requestNo" value="@group.Key" />

                        <div class="row">
                            <div class="col-md-8">
                                <input type="text"
                                       name="reviewNote"
                                       class="form-control"
                                       placeholder="Red notu" />
                            </div>

                            <div class="col-md-4 text-end">
                                <button type="submit" class="btn btn-danger">
                                    Belgeyi Reddet
                                </button>
                            </div>
                        </div>
                    </form>
                }
                else
                {
                    <table class="table table-bordered table-striped align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Ürün</th>
                                <th>Adet</th>
                                <th>Sebep</th>
                                <th>Açıklama</th>
                                <th>Durum</th>
                                <th>Yönetici Notu</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in group)
                            {
                                <tr>
                                    <td>@(item.Product?.Name ?? "-")</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.ReasonType</td>
                                    <td>@item.Reason</td>
                                    <td>@item.Status</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.ReviewNote) ? "-" : item.ReviewNote)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
}