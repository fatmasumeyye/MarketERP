@model List<MarketERP.Models.ReturnRequest>

@{
    ViewData["Title"] = "İade Taleplerim";
}

<h2 class="mb-4">İade Taleplerim</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-warning">
        Henüz oluşturduğun iade talebi yok.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Talep ID</th>
                <th>Satış ID</th>
                <th>Ürün</th>
                <th>Adet</th>
                <th>Sebep</th>
                <th>Durum</th>
                <th>Tarih</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.Id</td>
                    <td>@request.SaleId</td>
                    <td>@request.Product?.Name</td>
                    <td>@request.Quantity</td>
                    <td>@request.Reason</td>
                    <td>
                        @if (request.Status == "Beklemede")
                        {
                            <span class="badge bg-warning text-dark">Beklemede</span>
                        }
                        else if (request.Status == "Onaylandı")
                        {
                            <span class="badge bg-success">Onaylandı</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Reddedildi</span>
                        }
                    </td>
                    <td>@request.RequestedAt.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}