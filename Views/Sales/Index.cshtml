@model List<MarketERP.Models.Sale>

@{
    ViewData["Title"] = "Satış Listesi";
}

<h2 class="mb-4">Satış Listesi</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="alert alert-success">
            <h5>
                Toplam Satış Geliri:
                <strong>@ViewBag.TotalSalesRevenue ₺</strong>
            </h5>
        </div>
    </div>

    <div class="col-md-6">
        <div class="alert alert-info">
            <h5>
                Toplam Satış Sayısı:
                <strong>@ViewBag.TotalSalesCount</strong>
            </h5>
        </div>
    </div>
</div>

<div class="mb-3">
    <a href="/Sales/Retail" class="btn btn-primary">
        Perakende Satış
    </a>

    <a href="/Sales/Wholesale" class="btn btn-dark">
        Toptan Satış
    </a>
</div>

<form method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <input type="text"
                   name="search"
                   class="form-control"
                   placeholder="Müşteri adına göre ara..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-dark w-100">
                Ara
            </button>
        </div>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Satış ID</th>
            <th>Müşteri</th>
            <th>Toplam Tutar</th>
            <th>Tarih</th>
            <th>İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var sale in Model)
        {
            <tr>
                <td>@sale.Id</td>
                <td>@sale.Customer?.FullName</td>
                <td>@sale.TotalAmount ₺</td>
                <td>@sale.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>

                <td>
                    <a href="/Sales/Invoice/@sale.Id"
                           class="btn btn-info btn-sm">
                        Fatura
                    </a>

                    <a href="/Sales/Cancel/@sale.Id"
                           class="btn btn-danger btn-sm"
                                data-confirm-message="Bu satışı iptal etmek istediğinize emin misiniz? Stok geri eklenecek.">
                        Satışı İptal Et
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>