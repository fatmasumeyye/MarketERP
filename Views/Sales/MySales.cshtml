@model List<MarketERP.Models.Sale>

@{
    ViewData["Title"] = "Kendi Satışlarım";
}

<h2 class="mb-4">Kendi Satışlarım</h2>

<div class="alert alert-info">
    Bu ekranda sadece senin yaptığın satışlar listelenir. İade talepleri satış/fatura üzerinden oluşturulur.
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-warning">
        Henüz sana ait satış kaydı bulunmuyor.
    </div>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Satış ID</th>
                <th>Müşteri</th>
                <th>Ödeme Tipi</th>
                <th>Toplam Tutar</th>
                <th>Tarih</th>
                <th width="230">İşlem</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var sale in Model)
            {
                <tr>
                    <td>@sale.Id</td>
                    <td>@(sale.Customer?.FullName ?? "Nihai Tüketici")</td>
                    <td>@sale.PaymentType</td>
                    <td>@sale.TotalAmount.ToString("N2") ₺</td>
                    <td>@sale.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a href="/Sales/Invoice/@sale.Id?returnUrl=/Sales/MySales"
                               class="btn btn-info btn-sm">
                            Fatura
                        </a>

                        <a href="/Returns/Create/@sale.Id"
                               class="btn btn-warning btn-sm">
                            İade Talep Belgesi
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}