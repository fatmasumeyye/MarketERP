@{
    ViewData["Title"] = "Toptan Satış Talebi";

    var customers = ViewBag.Customers as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var products = ViewBag.Products as List<MarketERP.Models.Product> ?? new List<MarketERP.Models.Product>();
}

<h2 class="mb-4">Toptan Satış Talebi Oluştur</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="alert alert-info">
    Bu ekran satış personelinin toptan satış talebi oluşturması içindir.
    Talep oluşturulduktan sonra yönetici onayına gider.
</div>

<form asp-action="Wholesale" method="post">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            <strong>Firma / Talep Bilgileri</strong>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Müşteri / Firma</label>
                    <select name="customerId" class="form-control" asp-items="customers" required>
                        <option value="">Firma seçiniz</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Vade Tarihi</label>
                    <input type="date" name="dueDate" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">İskonto (%)</label>
                    <input type="number" name="discountRate" class="form-control" min="0" max="100" step="0.01" value="0" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Not</label>
                    <input type="text" name="note" class="form-control" placeholder="Örn: Kurumsal teklif" />
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <strong>Ürünler</strong>

            <button type="button" class="btn btn-sm btn-light" onclick="addRow()">
                + Ürün Satırı Ekle
            </button>
        </div>

        <div class="card-body">
            <table class="table table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Ürün</th>
                        <th width="160">Miktar</th>
                        <th width="120">İşlem</th>
                    </tr>
                </thead>

                <tbody id="productRows">
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <a href="/Sales" class="btn btn-secondary">Satış Listesine Dön</a>

        <button type="submit" class="btn btn-success"
                onclick="return confirm('Toptan satış talebi yönetici onayına gönderilecek. Devam edilsin mi?');">
            Talebi Oluştur
        </button>
    </div>
</form>

<script>
    const products = [
        @foreach (var p in products)
        {
                <text>{ id: @p.Id, name: "@p.Name.Replace("\"", "\\\"")", stock: @p.StockQuantity, price: @p.SalePrice.ToString(System.Globalization.CultureInfo.InvariantCulture) },</text>
        }
    ];

    function addRow() {
        const tbody = document.getElementById("productRows");

        const tr = document.createElement("tr");

        let productOptions = '<option value="">Ürün seçiniz</option>';

        products.forEach(p => {
            productOptions += `<option value="${p.id}">${p.name} | Stok: ${p.stock} | Fiyat: ${p.price} ₺</option>`;
        });

        tr.innerHTML = `
            <td>
                <select name="productIds" class="form-control" required>
                    ${productOptions}
                </select>
            </td>

            <td>
                <input type="number" name="quantities" class="form-control" min="1" value="1" required />
            </td>

            <td>
                <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('tr').remove()">
                    Sil
                </button>
            </td>
        `;

        tbody.appendChild(tr);
    }

    addRow();
</script>