@model List<MarketERP.Models.SavedQuery>

@{
    ViewData["Title"] = "Kayıtlı Sorgular";
}

<h2 class="mb-4">Kayıtlı Sorgular</h2>

<a href="/SqlEditor" class="btn btn-secondary mb-3">
    SQL Paneline Dön
</a>

@if (Model.Count == 0)
{
    <div class="alert alert-warning">
        Henüz kayıtlı sorgu bulunmuyor.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Başlık</th>
                <th>SQL Sorgusu</th>
                <th>İşlem</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var query in Model)
            {
                <tr>
                    <td>@query.Title</td>
                    <td>
                        <code>@query.SqlQuery</code>
                    </td>
                    <td>
                        <a href="/SqlEditor?query=@Uri.EscapeDataString(query.SqlQuery)"
                               class="btn btn-primary btn-sm">
                            Aç
                        </a>

                        <a href="/SqlEditor/DeleteSavedQuery/@query.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bu kayıtlı sorguyu silmek istediğinize emin misiniz?')">
                            Sil
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}