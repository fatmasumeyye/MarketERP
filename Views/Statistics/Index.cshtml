@using MarketERP.Models
@{
    ViewData["Title"] = "İstatistikler";

    var topSellingProducts =
        ViewBag.TopSellingProducts as List<Tuple<string, int, decimal>>
        ?? new List<Tuple<string, int, decimal>>();
    var paymentTypeDistribution =
        ViewBag.PaymentTypeDistribution as List<Tuple<string, decimal>>
        ?? new List<Tuple<string, decimal>>();
    var topCustomers =
        ViewBag.TopCustomers as List<Tuple<string, int, decimal>>
        ?? new List<Tuple<string, int, decimal>>();
    var criticalProducts =
        ViewBag.CriticalProducts as List<Product>
        ?? new List<Product>();
    var outOfStockProducts =
        ViewBag.OutOfStockProducts as List<Product>
        ?? new List<Product>();
    var recentSales =
        ViewBag.RecentSales as List<Sale>
        ?? new List<Sale>();
}

<style>
    .erp-stat-card {
        display: block;
        min-height: 150px;
        border: 1px solid #e2e8f0;
        border-left: 4px solid #2563eb;
        border-radius: 16px;
        background: #fff;
        color: #0f172a;
        text-decoration: none;
        box-shadow: 0 2px 5px rgba(15, 23, 42, .04), 0 10px 26px rgba(15, 23, 42, .05);
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .erp-stat-card:hover {
        color: #0f172a;
        transform: translateY(-2px);
        box-shadow: 0 12px 30px rgba(15, 23, 42, .09);
    }

    .erp-stat-card .card-body {
        display: grid;
        grid-template-columns: 48px minmax(0, 1fr);
        align-content: center;
        column-gap: 16px;
        min-height: 146px;
        padding: 22px;
    }

    .erp-stat-icon {
        grid-column: 1;
        grid-row: 1 / span 3;
        align-self: center;
        display: grid;
        place-items: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #eff6ff;
        color: #2563eb;
        font-size: 21px;
    }

    .erp-stat-card .card-body > div:not(.erp-stat-icon),
    .erp-stat-card .card-body > h2,
    .erp-stat-card .card-body > small {
        grid-column: 2;
    }

    .erp-stat-card .card-body > div:not(.erp-stat-icon) {
        color: #64748b;
        font-size: 13px;
        font-weight: 500;
    }

    .erp-stat-card h2 {
        margin-top: 8px !important;
        color: #0f172a;
        font-size: 1.75rem;
        font-weight: 700;
    }

    .erp-stat-card small { color: #64748b; }

    .erp-stat-primary { border-left-color: #2563eb; }
    .erp-stat-info { border-left-color: #0891b2; }
    .erp-stat-warning { border-left-color: #f59e0b; }
    .erp-stat-danger { border-left-color: #dc2626; }
    .erp-stat-success { border-left-color: #16a34a; }
    .erp-stat-muted { border-left-color: #64748b; }
    .erp-stat-info .erp-stat-icon { background: #ecfeff; color: #0891b2; }
    .erp-stat-warning .erp-stat-icon { background: #fffbeb; color: #b45309; }
    .erp-stat-danger .erp-stat-icon { background: #fef2f2; color: #dc2626; }
    .erp-stat-success .erp-stat-icon { background: #f0fdf4; color: #16a34a; }
    .erp-stat-muted .erp-stat-icon { background: #f1f5f9; color: #64748b; }

    .erp-panel {
        border: 0;
        border-radius: 16px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, .07);
    }

    .chart-panel {
        min-height: 360px;
    }

    .chart-wrap {
        position: relative;
        min-height: 280px;
    }

</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">ERP İstatistikleri</h2>
        <p class="text-muted mb-0">Satış, stok ve operasyon performansı</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sales" asp-action="Index" asp-route-dateFilter="today"
           class="card erp-stat-card erp-stat-primary">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-currency-exchange"></i>
                <div>Günlük Satış Toplamı</div>
                <h2 class="mt-2 mb-0">@(((decimal)ViewBag.TodayRevenue).ToString("N2")) ₺</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sales" asp-action="Index" asp-route-dateFilter="month"
           class="card erp-stat-card erp-stat-success">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-calendar2-check"></i>
                <div>Aylık Satış Toplamı</div>
                <h2 class="mt-2 mb-0">@(((decimal)ViewBag.MonthlyRevenue).ToString("N2")) ₺</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sales" asp-action="Index" class="card erp-stat-card erp-stat-primary">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-receipt"></i>
                <div>Toplam Satış Sayısı</div>
                <h2 class="mt-2 mb-0">@ViewBag.SaleCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Customers" asp-action="Index" class="card erp-stat-card erp-stat-info">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-people"></i>
                <div>Müşteri Sayısı</div>
                <h2 class="mt-2 mb-0">@ViewBag.CustomerCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Products" asp-action="Index" asp-route-stockStatus="critical"
           class="card erp-stat-card erp-stat-warning">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-exclamation-triangle"></i>
                <div>Kritik Stoktaki Ürünler</div>
                <h2 class="mt-2 mb-0">@ViewBag.CriticalStockCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Products" asp-action="Index" asp-route-stockStatus="out"
           class="card erp-stat-card erp-stat-danger">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-box-seam"></i>
                <div>Stokta Biten Ürünler</div>
                <h2 class="mt-2 mb-0">@ViewBag.OutOfStockCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Returns" asp-action="Index" asp-route-status="Beklemede"
           class="card erp-stat-card erp-stat-warning">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-arrow-return-left"></i>
                <div>Bekleyen İade Talepleri</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingReturnRequestCount</h2>
                <small>Satışlara oranı: %@ViewBag.ReturnRate</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="WholesaleSales" asp-action="Index" asp-route-status="Onay Bekliyor"
           class="card erp-stat-card erp-stat-warning">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-truck"></i>
                <div>Bekleyen Toptan Talepler</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingWholesaleRequestCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="CashRegister" asp-action="Index" asp-route-status="Beklemede"
           class="card erp-stat-card erp-stat-warning">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-cash-stack"></i>
                <div>Bekleyen Kasa Kapanışları</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingCashClosingCount</h2>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="EmployeeLeaves" asp-action="Index"
           class="card erp-stat-card erp-stat-info">
            <div class="card-body">
                <i class="erp-stat-icon bi bi-calendar2-week"></i>
                <div>Bekleyen İzin Talepleri</div>
                <h2 class="mt-2 mb-0">@ViewBag.PendingLeaveCount</h2>
            </div>
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="card erp-panel chart-panel h-100">
            <div class="card-header bg-white fw-semibold">Son 30 Gün Satış Grafiği</div>
            <div class="card-body chart-wrap">
                @if ((bool)ViewBag.HasDailySalesData)
                {
                    <canvas id="dailySalesChart"></canvas>
                }
                else
                {
                    <div class="h-100 d-flex align-items-center justify-content-center text-muted">
                        Son 30 gün için satış verisi bulunmuyor.
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card erp-panel chart-panel h-100">
            <div class="card-header bg-white fw-semibold">Ödeme Tipi Dağılımı</div>
            <div class="card-body chart-wrap">
                @if ((bool)ViewBag.HasPaymentTypeData)
                {
                    <canvas id="paymentTypeChart"></canvas>
                }
                else
                {
                    <div class="h-100 d-flex align-items-center justify-content-center text-muted">
                        Ödeme tipi verisi bulunmuyor.
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card erp-panel chart-panel h-100">
            <div class="card-header bg-white fw-semibold">Kategori Bazlı Satış</div>
            <div class="card-body chart-wrap">
                @if ((bool)ViewBag.HasCategorySalesData)
                {
                    <canvas id="categorySalesChart"></canvas>
                }
                else
                {
                    <div class="h-100 d-flex align-items-center justify-content-center text-muted">
                        Kategori satış verisi bulunmuyor.
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card erp-panel chart-panel h-100">
            <div class="card-header bg-white fw-semibold">En Çok Satan Ürünler</div>
            <div class="card-body chart-wrap">
                @if ((bool)ViewBag.HasTopProductData)
                {
                    <canvas id="topProductsChart"></canvas>
                }
                else
                {
                    <div class="h-100 d-flex align-items-center justify-content-center text-muted">
                        Ürün satış verisi bulunmuyor.
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card erp-panel chart-panel h-100">
            <div class="card-header bg-white fw-semibold">İade Durumları</div>
            <div class="card-body chart-wrap">
                @if ((bool)ViewBag.HasReturnStatusData)
                {
                    <canvas id="returnStatusChart"></canvas>
                }
                else
                {
                    <div class="h-100 d-flex align-items-center justify-content-center text-muted">
                        İade talebi verisi bulunmuyor.
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card erp-panel chart-panel h-100">
            <div class="card-header bg-white fw-semibold">Stok Durumu</div>
            <div class="card-body chart-wrap">
                @if ((bool)ViewBag.HasStockStatusData)
                {
                    <canvas id="stockStatusChart"></canvas>
                }
                else
                {
                    <div class="h-100 d-flex align-items-center justify-content-center text-muted">
                        Ürün stok verisi bulunmuyor.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card erp-panel h-100">
            <div class="card-header bg-white fw-semibold">En Çok Satan Ürünler</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ürün</th>
                            <th class="text-end">Adet</th>
                            <th class="text-end">Ciro</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (topSellingProducts.Any())
                        {
                            foreach (var item in topSellingProducts)
                            {
                                <tr>
                                    <td>@item.Item1</td>
                                    <td class="text-end">@item.Item2</td>
                                    <td class="text-end">@item.Item3.ToString("N2") ₺</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">Satış verisi bulunmuyor.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card erp-panel h-100">
            <div class="card-header bg-white fw-semibold">Tahsilat / Ödeme Tipi Dağılımı</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ödeme Tipi</th>
                            <th class="text-end">Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (paymentTypeDistribution.Any())
                        {
                            foreach (var item in paymentTypeDistribution)
                            {
                                <tr>
                                    <td>@item.Item1</td>
                                    <td class="text-end">@item.Item2.ToString("N2") ₺</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="2" class="text-center text-muted py-4">Ödeme verisi bulunmuyor.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const chartColors = [
            '#355c9a', '#2d6a4f', '#ca8a04', '#b91c1c',
            '#7c3aed', '#0f766e', '#4b5563', '#0ea5e9',
            '#db2777', '#65a30d'
        ];

        @if ((bool)ViewBag.HasDailySalesData)
        {
            <text>
            new Chart(document.getElementById('dailySalesChart'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.DailySalesLabels)),
                    datasets: [
                        {
                            label: 'Satış Tutarı',
                            data: @Html.Raw(Json.Serialize(ViewBag.DailySalesRevenue)),
                            borderColor: '#355c9a',
                            backgroundColor: 'rgba(53, 92, 154, .12)',
                            fill: true,
                            tension: .3,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Satış Adedi',
                            data: @Html.Raw(Json.Serialize(ViewBag.DailySalesCounts)),
                            borderColor: '#ca8a04',
                            backgroundColor: '#ca8a04',
                            type: 'bar',
                            yAxisID: 'yCount'
                        }
                    ]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true },
                        yCount: {
                            beginAtZero: true,
                            position: 'right',
                            grid: { drawOnChartArea: false },
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
            </text>
        }

        @if ((bool)ViewBag.HasCategorySalesData)
        {
            <text>
            new Chart(document.getElementById('categorySalesChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.CategorySalesLabels)),
                    datasets: [{
                        label: 'Satış Tutarı',
                        data: @Html.Raw(Json.Serialize(ViewBag.CategorySalesData)),
                        backgroundColor: chartColors
                    }]
                },
                options: { maintainAspectRatio: false, indexAxis: 'y' }
            });
            </text>
        }

        @if ((bool)ViewBag.HasTopProductData)
        {
            <text>
            new Chart(document.getElementById('topProductsChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.TopProductChartLabels)),
                    datasets: [{
                        label: 'Satılan Adet',
                        data: @Html.Raw(Json.Serialize(ViewBag.TopProductChartData)),
                        backgroundColor: '#0f766e'
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    scales: { x: { beginAtZero: true, ticks: { precision: 0 } } }
                }
            });
            </text>
        }

        @if ((bool)ViewBag.HasPaymentTypeData)
        {
            <text>
            new Chart(document.getElementById('paymentTypeChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.PaymentTypeChartLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(ViewBag.PaymentTypeChartData)),
                        backgroundColor: chartColors
                    }]
                },
                options: { maintainAspectRatio: false }
            });
            </text>
        }

        @if ((bool)ViewBag.HasReturnStatusData)
        {
            <text>
            new Chart(document.getElementById('returnStatusChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.ReturnStatusLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(ViewBag.ReturnStatusData)),
                        backgroundColor: chartColors
                    }]
                },
                options: { maintainAspectRatio: false }
            });
            </text>
        }

        @if ((bool)ViewBag.HasStockStatusData)
        {
            <text>
            new Chart(document.getElementById('stockStatusChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.StockStatusLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(ViewBag.StockStatusData)),
                        backgroundColor: ['#2d6a4f', '#ca8a04', '#b91c1c']
                    }]
                },
                options: { maintainAspectRatio: false }
            });
            </text>
        }
    </script>
}

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card erp-panel h-100">
            <div class="card-header bg-white fw-semibold">Kritik Stok</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Ürün</th><th class="text-end">Stok</th><th class="text-end">Kritik Seviye</th></tr>
                    </thead>
                    <tbody>
                        @if (criticalProducts.Any())
                        {
                            foreach (var product in criticalProducts)
                            {
                                <tr>
                                    <td>@product.Name</td>
                                    <td class="text-end">@product.StockQuantity</td>
                                    <td class="text-end">@product.CriticalStock</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">Kritik stokta ürün yok.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card erp-panel h-100">
            <div class="card-header bg-white fw-semibold">Stokta Biten Ürünler</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Ürün</th><th class="text-end">Stok</th></tr>
                    </thead>
                    <tbody>
                        @if (outOfStockProducts.Any())
                        {
                            foreach (var product in outOfStockProducts)
                            {
                                <tr>
                                    <td>@product.Name</td>
                                    <td class="text-end"><span class="badge bg-danger">@product.StockQuantity</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="2" class="text-center text-muted py-4">Stokta biten ürün yok.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card erp-panel mb-4">
    <div class="card-header bg-white fw-semibold">En Çok Alışveriş Yapan Müşteriler</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Müşteri</th><th class="text-end">Satış Sayısı</th><th class="text-end">Toplam Alışveriş</th></tr>
            </thead>
            <tbody>
                @if (topCustomers.Any())
                {
                    foreach (var customer in topCustomers)
                    {
                        <tr>
                            <td>@customer.Item1</td>
                            <td class="text-end">@customer.Item2</td>
                            <td class="text-end">@customer.Item3.ToString("N2") ₺</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">Müşteri satış verisi bulunmuyor.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card erp-panel">
    <div class="card-header bg-white fw-semibold">Son Satışlar</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Satış No</th><th>Müşteri</th><th>Çalışan</th><th>Ödeme</th><th class="text-end">Tutar</th><th>Tarih</th></tr>
            </thead>
            <tbody>
                @if (recentSales.Any())
                {
                    foreach (var sale in recentSales)
                    {
                        <tr>
                            <td>#@sale.Id</td>
                            <td>@(sale.Customer?.FullName ?? "Nihai Tüketici")</td>
                            <td>@(sale.Employee?.FullName ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(sale.PaymentType) ? "-" : sale.PaymentType)</td>
                            <td class="text-end">@sale.TotalAmount.ToString("N2") ₺</td>
                            <td>@sale.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Satış kaydı bulunmuyor.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
