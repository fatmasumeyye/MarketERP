@model MarketERP.Models.SupplierDetailViewModel
@{ ViewData["Title"]="Tedarikçi Detayı"; var s=Model.Supplier; }
<div class="erp-page-header"><div><span class="erp-page-eyebrow">TEDARİKÇİ KARTI</span><h2>@s.CompanyName</h2><p>Tedarikçi bilgileri ve satın alma özeti.</p></div><div class="erp-page-actions"><a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Düzenle</a><a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a></div></div>
<div class="row g-3 mb-4"><div class="col-md-4"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Toplam Satın Alma</div><div class="erp-kpi-value">@Model.TotalPurchases.ToString("N2") ₺</div></div></div><div class="col-md-4"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Sipariş Sayısı</div><div class="erp-kpi-value">@Model.TotalOrders</div></div></div><div class="col-md-4"><div class="erp-kpi-card erp-kpi-surface"><div class="erp-kpi-label">Son Sipariş</div><div class="erp-kpi-value fs-5">@(Model.LastOrder?.OrderDate.ToString("dd.MM.yyyy") ?? "Kayıt yok")</div><small>@(Model.LastOrder == null ? "—" : $"PO-{Model.LastOrder.Id:000000}")</small></div></div></div>
<div class="card"><div class="card-header"><h3 class="erp-card-title">Tedarikçi Bilgileri</h3></div><div class="card-body"><div class="row g-4"><div class="col-md-4"><strong>Telefon</strong><div>@(string.IsNullOrWhiteSpace(s.Phone)?"Tanımlanmadı":s.Phone)</div></div><div class="col-md-4"><strong>E-posta</strong><div>@(string.IsNullOrWhiteSpace(s.Email)?"Tanımlanmadı":s.Email)</div></div><div class="col-md-4"><strong>Durum</strong><div><span class="badge @(s.IsActive?"bg-success":"bg-secondary")">@(s.IsActive?"Aktif":"Pasif")</span></div></div><div class="col-12"><strong>Adres</strong><div>@(string.IsNullOrWhiteSpace(s.Address)?"Tanımlanmadı":s.Address)</div></div></div></div></div>
